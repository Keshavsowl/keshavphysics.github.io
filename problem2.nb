Cell[TextData[{
 "Angular power distribution for half wave antenna\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    FractionBox["dP", "d\[CapitalOmega]"], " ", "=", " ", 
    SuperscriptBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        SubscriptBox["I", "o"], ")"}], "2"], "[", 
      FractionBox[
       RowBox[{
        RowBox[{"cos", "(", 
         FractionBox[
          RowBox[{"kdcos", "(", "\[Theta]", ")"}], "2"], ")"}], "-", 
        RowBox[{"cos", "(", 
         FractionBox["kd", "2"], ")"}]}], 
       RowBox[{"sin", "(", "\[Theta]", ")"}]], "]"}], "2"]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"kd", " ", "=", " ", 
    RowBox[{"2", "\[Pi]"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox["dP", "d\[CapitalOmega]"], " ", "=", " ", 
    SuperscriptBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        SubscriptBox["I", "o"], ")"}], "2"], "[", 
      FractionBox[
       RowBox[{
        RowBox[{"cos", "(", 
         RowBox[{"\[Pi]cos", "(", "\[Theta]", ")"}], ")"}], "-", 
        RowBox[{"cos", "(", "\[Pi]", ")"}]}], 
       RowBox[{"sin", "(", "\[Theta]", ")"}]], "]"}], "2"]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox["dP", "d\[CapitalOmega]"], " ", "=", " ", 
    SuperscriptBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        SubscriptBox["I", "o"], ")"}], "2"], "[", 
      FractionBox[
       RowBox[{
        RowBox[{"cos", "(", 
         RowBox[{"\[Pi]cos", "(", "\[Theta]", ")"}], ")"}], "-", 
        RowBox[{"cos", "(", "\[Pi]", ")"}]}], 
       RowBox[{"sin", "(", "\[Theta]", ")"}]], "]"}], "2"]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox["dP", "d\[CapitalOmega]"], "=", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox[
       RowBox[{"(", 
        SubscriptBox["I", "0"], ")"}], "2"], 
      RowBox[{"2", "\[Pi]"}]], 
     FractionBox[
      RowBox[{
       SuperscriptBox["cos", "4"], "(", 
       RowBox[{
        FractionBox["\[Pi]", "2"], 
        RowBox[{"cos", "(", "\[Theta]", ")"}]}], ")"}], 
      RowBox[{
       SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"P", " ", "=", " ", 
    RowBox[{"\[Integral]", 
     RowBox[{
      FractionBox[
       SuperscriptBox[
        RowBox[{"(", 
         SubscriptBox["I", "0"], ")"}], "2"], 
       RowBox[{"2", "\[Pi]"}]], 
      FractionBox[
       RowBox[{
        SuperscriptBox["cos", "4"], "(", 
        RowBox[{
         FractionBox["\[Pi]", "2"], 
         RowBox[{"cos", "(", "\[Theta]", ")"}]}], ")"}], 
       RowBox[{
        SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]], 
      RowBox[{"\[DifferentialD]", "\[CapitalOmega]"}]}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"P", " ", "=", " ", 
    RowBox[{"\[Integral]", 
     RowBox[{
      FractionBox[
       SuperscriptBox[
        RowBox[{"(", 
         SubscriptBox["I", "0"], ")"}], "2"], 
       RowBox[{"2", "\[Pi]"}]], 
      FractionBox[
       RowBox[{
        SuperscriptBox["cos", "4"], "(", 
        RowBox[{
         FractionBox["\[Pi]", "2"], 
         RowBox[{"cos", "(", "\[Theta]", ")"}]}], ")"}], 
       RowBox[{
        SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]], 
      RowBox[{"sin", "(", "\[Theta]", ")"}], "d\[Phi]", 
      RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"P", " ", "=", " ", 
    RowBox[{"\[Integral]", 
     RowBox[{
