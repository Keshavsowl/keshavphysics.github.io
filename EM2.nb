Cell[TextData[{
 "Let us calculate two  quantities of the above given matrix \n\[Implies]",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", 
         SuperscriptBox["v", "2"]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["v1", "2"], "+", 
           SuperscriptBox["v2", "2"], "+", 
           SuperscriptBox["v3", "2"]}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[Gamma]"}], ")"}]}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "\[Gamma]"}], ")"}]}], 
     SuperscriptBox["v", "4"]], "-", 
    FractionBox[
     SuperscriptBox["\[Gamma]", "2"], 
     SuperscriptBox["c", "2"]]}], "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", 
          SuperscriptBox["v", "2"]}], "+", 
         RowBox[{
          RowBox[{"(", 
           SuperscriptBox["v", "2"], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", "\[Gamma]"}], ")"}]}]}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "\[Gamma]"}], ")"}]}], 
      SuperscriptBox["v", "4"]], "-", 
     FractionBox[
      SuperscriptBox["\[Gamma]", "2"], 
      SuperscriptBox["c", "2"]]}], "=", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", " ", "+", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", "\[Gamma]"}], ")"}]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "\[Gamma]"}], ")"}]}], 
       SuperscriptBox["v", "2"]], "-", 
      FractionBox[
       SuperscriptBox["\[Gamma]", "2"], 
       SuperscriptBox["c", "2"]]}], "=", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", "\[Gamma]"}], ")"}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[Gamma]"}], ")"}]}], 
        SuperscriptBox["v", "2"]], "-", 
       FractionBox[
        SuperscriptBox["\[Gamma]", "2"], 
        SuperscriptBox["c", "2"]]}], "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "+", "\[Gamma]"}], ")"}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", "\[Gamma]"}], ")"}]}], 
         SuperscriptBox["v", "2"]], "-", 
        FractionBox[
         SuperscriptBox["\[Gamma]", "2"], 
         SuperscriptBox["c", "2"]]}], "=", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{"(", 
           RowBox[{"1", "-", 
            SuperscriptBox["\[Gamma]", "2"]}], ")"}], 
          SuperscriptBox["v", "2"]], " ", "-", 
         FractionBox[
          SuperscriptBox["\[Gamma]", "2"], 
          SuperscriptBox["c", "2"]]}], "=", 
        RowBox[{
         FractionBox[
          RowBox[{
           RowBox[{
            SuperscriptBox["c", "2"], 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              SuperscriptBox["\[Gamma]", "2"]}], ")"}]}], "-", 
           RowBox[{
            SuperscriptBox["v", "2"], 
            SuperscriptBox["\[Gamma]", "2"]}]}], 
          RowBox[{
           SuperscriptBox["c", "2"], 
           SuperscriptBox["v", "2"]}]], " ", "=", 
         RowBox[{
          FractionBox[
           RowBox[{
            SuperscriptBox["c", "2"], "-", 
            RowBox[{
             SuperscriptBox["c", "2"], 
             SuperscriptBox["\[Gamma]", "2"]}], "-", 
            RowBox[{
             SuperscriptBox["v", "2"], 
             SuperscriptBox["\[Gamma]", "2"]}]}], 
           RowBox[{
            SuperscriptBox["c", "2"], 
            SuperscriptBox["v", "2"]}]], "=", 
          RowBox[{
           FractionBox[
            RowBox[{
             SuperscriptBox["c", "2"], "-", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                SuperscriptBox["c", "2"], "-", 
                SuperscriptBox["v", "2"]}], ")"}], 
              SuperscriptBox["\[Gamma]", "2"]}]}], 
            RowBox[{
             SuperscriptBox["c", "2"], 
             SuperscriptBox["v", "2"]}]], "=", 
           RowBox[{
            FractionBox[
             RowBox[{
              SuperscriptBox["c", "2"], "-", 
              FractionBox[
               RowBox[{
                SuperscriptBox["c", "2"], 
                RowBox[{"(", 
                 RowBox[{
                  SuperscriptBox["c", "2"], "-", 
                  SuperscriptBox["v", "2"]}], ")"}]}], 
               RowBox[{"(", 
                RowBox[{
                 SuperscriptBox["c", "2"], "-", 
                 SuperscriptBox["v", "2"]}], ")"}]]}], 
             RowBox[{
