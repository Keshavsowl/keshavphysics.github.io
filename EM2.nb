              SuperscriptBox["v", "2"]}]], "=", " ", 
            RowBox[{
             FractionBox[
              RowBox[{
               SuperscriptBox["c", "2"], "-", 
               SuperscriptBox["c", "2"]}], 
              RowBox[{
               SuperscriptBox["c", "2"], 
               SuperscriptBox["v", "2"]}]], " ", "=", " ", "0", 
             " "}]}]}]}]}]}]}]}]}]}]}]],
