  "f7a0bf3f-7f8e-944e-94cd-1054f8f7bc1c"],
 " = 1\nProper Transformation - > Transformation where det(\[CapitalLambda]) \
= +1 and \n\nImproper Transformation - > Transformation where det(\
\[CapitalLambda]) = +1 and \n\n"
}], "Text",
