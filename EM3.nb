Cell[TextData[{
 "Electric field due to point charge = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["kQ", 
      SuperscriptBox["r", "2"]], 
     OverscriptBox["r", "^"]}], "=", 
    FractionBox[
     RowBox[{"kQ", " ", 
      OverscriptBox["r", 
       RowBox[{"\[Dash]", ">"}]]}], 
     SuperscriptBox["r", "3"]], " "}], TraditionalForm]],ExpressionUUID->
  "4768ed43-3988-7a4b-945a-3829ff1b9185"],
 "= ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"kQ", "(", 
     RowBox[{
      OverscriptBox["x", "^"], "+", 
      OverscriptBox["y", "^"], "+", 
      OverscriptBox["z", "^"]}], ")"}], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"], "+", 
       SuperscriptBox["z", "2"]}], ")"}], 
     FractionBox["3", "2"]]], TraditionalForm]],ExpressionUUID->
  "d941964a-69db-484a-a599-d65237153584"]
}], "Text",
 CellChangeTimes->{{3.968006110363312*^9, 3.9680061468176804`*^9}, {
