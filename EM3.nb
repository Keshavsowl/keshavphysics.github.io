Cell[CellGroupData[{

Cell["i)", "Subsubsection",
 CellChangeTimes->{{3.968422871971363*^9, 
  3.9684228840477734`*^9}},ExpressionUUID->"76636cab-1bb6-3740-b263-\
ae51f0fbb3c5"],

Cell[TextData[{
 "Let one wire is one the z axis. and other wire is on the plane (0,0,a)\n\
From gauss law\n2\[Pi]rl E= ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["q", "0"], "l"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4e089f19-a573-334b-9421-934f6a9dd7cc"],
 "\nHence Electric field at any point due to the first wire will be given by\n\
",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    OverscriptBox[
     SubscriptBox["E", "1"], "\[Rule]"], "=", 
    RowBox[{
     RowBox[{
      FractionBox[
       SubscriptBox["q", "0"], 
       RowBox[{"2", "\[Pi]r"}]], 
      OverscriptBox["r", "^"]}], " ", "=", " ", 
     FractionBox[
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["q", "0"], " ", 
         RowBox[{"(", "x", ")"}], " ", 
         OverscriptBox[
          RowBox[{" ", "x"}], "^"]}], " ", "+", 
        RowBox[{"y", "  ", 
         OverscriptBox["y", "^"]}]}], ")"}], 
      RowBox[{"2", 
       RowBox[{"\[Pi]", "(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"]}], ")"}]}]]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"Electric", "  ", "due", " ", "to", " ", "second", " ", "wire"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["E", "\[Rule]"], "2"], " ", "=", " ", 
    FractionBox[
     RowBox[{
      SubscriptBox["q", "0"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "-", "a"}], ")"}], 
         OverscriptBox["x", "^"]}], " ", "+", " ", 
        RowBox[{"y", " ", 
         OverscriptBox["y", "^"]}]}]}]}], 
     RowBox[{"2", 
      RowBox[{"\[Pi]", "(", 
       RowBox[{
        SuperscriptBox["x", "2"], "+", 
        SuperscriptBox["y", "2"]}], ")"}]}]]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["E", "\[Rule]"], "T"], " ", "=", " ", 
    RowBox[{
     FractionBox[
      RowBox[{
       SubscriptBox["q", "0"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "  ", 
          OverscriptBox["x", "^"]}], " ", "+", " ", 
         RowBox[{"y", " ", 
          OverscriptBox["y", "^"]}]}], ")"}]}], 
      RowBox[{"2", 
       RowBox[{"\[Pi]", "(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"]}], ")"}]}]], " ", "+", " ", 
     FractionBox[
      RowBox[{
       SubscriptBox["q", "0"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "-", "a"}], ")"}], 
          OverscriptBox["x", "^"]}], " ", "+", " ", 
         RowBox[{"y", " ", 
          OverscriptBox["y", "^"]}]}], ")"}]}], 
      RowBox[{"2", 
       RowBox[{"\[Pi]", "(", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"x", "-", "a"}], ")"}], "2"], "+", 
         SuperscriptBox["y", "2"]}], ")"}]}]]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "The", " ", "total", " ", "electric", " ", "feild", " ", "on", " ", "the", 
    " ", "wire", " ", "2", " ", "due", " ", "to", " ", "wire", " ", "1"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    OverscriptBox[
     SubscriptBox["E", "1"], "\[Rule]"], "=", 
    RowBox[{
     FractionBox[
      SubscriptBox["q", "0"], 
      RowBox[{"2", "\[Pi]a"}]], 
     OverscriptBox["r", "^"]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
    "Total", " ", "force", " ", "of", " ", "on", " ", "unit", " ", "length"}],
     " ", "=", "  ", 
    RowBox[{
    "charge", " ", "on", " ", "unit", " ", "lenght", " ", "*", "Electric", " ",
      "field"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox[
     OverscriptBox["F", "\[Rule]"], "L"], "=", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox[
       SubscriptBox["q", "0"], "2"], 
      RowBox[{"2", "\[Pi]a"}]], 
     OverscriptBox["r", "^"]}]}], TraditionalForm]}],
  FormatType->TraditionalForm,ExpressionUUID->
  "f50f527f-7690-5e45-b735-52c000852580"],
 " "
}], "Text",
 CellChangeTimes->{{3.9683618924360714`*^9, 3.968361895251663*^9}, {
  3.9683638082464027`*^9, 3.96836380857926*^9}, {3.968421955905218*^9, 
  3.9684224631454697`*^9}, {3.968422561439581*^9, 3.968422591747513*^9}, {
  3.96842264680402*^9, 3.968422896001669*^9}, {3.9684238879571514`*^9, 
  3.96842389198699*^9}, {3.968425196893751*^9, 
  3.968425196893751*^9}},ExpressionUUID->"66f7568f-63df-6547-b7ad-\
bb0876b92e15"]
}, Open  ]],

Cell[CellGroupData[{

Cell["ii)", "Subsubsection",
 CellChangeTimes->{{3.9684228980253735`*^9, 
  3.968422906531328*^9}},ExpressionUUID->"2cdeeb7f-b534-794e-8390-\
c939f11d0064"],

Cell[TextData[{
 "In the second part we have solved how the transformed electric field and \
magnetic field will look like for boost in the  direction. However here we \
were going from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"O", "'"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8429341a-2f74-a34e-a76c-fb145a0ed711"],
 " frame to O . Hence transformation will be little bit modified\n",
 Cell[BoxData[
  RowBox[{"           ", 
   RowBox[{
    RowBox[{
    "here", " ", "we", " ", "are", " ", "working", " ", "in", " ", "units", " ",
      "where", " ", "c"}], " ", "=", " ", "1"}]}]],ExpressionUUID->
  "e83b8f2a-7ad5-ae40-98ec-67aac1a16612"],
 "\nAnd magnetic field will look like\n",
 Cell[BoxData[{
  RowBox[{
   RowBox[{
    SubscriptBox[
     RowBox[{"E", "'"}], "x"], " ", "=", "    ", 
    RowBox[{"\[Gamma]", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["E", "x"], " ", "+", " ", 
       SubscriptBox["vB", "y"]}], ")"}]}]}], 
   "                                          "}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     RowBox[{"E", "'"}], "y"], "  ", "=", " ", 
    RowBox[{"\[Gamma]", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["E", "y"], " ", "-", 
       SubscriptBox["vB", "x"]}], ")"}]}]}], " "}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     RowBox[{"E", "'"}], "z"], " ", "=", "  ", 
    SubscriptBox["E", "z"]}], " "}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     RowBox[{"B", "'"}], "x"], " ", "=", "    ", 
    RowBox[{"\[Gamma]", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["B", "x"], "-", " ", 
       SubscriptBox["vE", "y"]}], ")"}]}]}], 
   "                                          "}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     RowBox[{"B", "'"}], "y"], "  ", "=", " ", 
    RowBox[{"\[Gamma]", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["B", "y"], " ", "+", 
       SubscriptBox["vE", "x"]}], ")"}]}]}], " "}], "\[IndentingNewLine]", 
  RowBox[{
   SubscriptBox[
    RowBox[{"B", "'"}], "z"], " ", "=", "  ", 
   SubscriptBox["B", "z"]}], "\[IndentingNewLine]", 
  RowBox[{
  "Hence", "  ", "Electric", " ", "field", " ", "and", " ", "Magnetic", " ", 
   "field", " ", "will", " ", "look", " ", "like"}], "\[IndentingNewLine]", 
  RowBox[{"    ", 
   RowBox[{
    SubscriptBox[
     RowBox[{
      OverscriptBox["E", "\[Rule]"], "'"}], "T"], " ", "=", " ", 
    RowBox[{
     RowBox[{"\[Gamma]", 
      RowBox[{"(", 
       FormBox[
        RowBox[{
         FractionBox[
          RowBox[{
           SubscriptBox["q", "0"], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"x", "  ", 
              OverscriptBox["x", "^"]}], " ", "+", " ", 
             RowBox[{"y", " ", 
              OverscriptBox["y", "^"]}]}], ")"}]}], 
          RowBox[{"2", 
           RowBox[{"\[Pi]", "(", 
            RowBox[{
             SuperscriptBox["x", "2"], "+", 
             SuperscriptBox["y", "2"]}], ")"}]}]], " ", "+", " ", 
         FractionBox[
          RowBox[{
           SubscriptBox["q", "0"], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"x", "-", "a"}], ")"}], 
              OverscriptBox["x", "^"]}], " ", "+", " ", 
             RowBox[{"y", " ", 
              OverscriptBox["y", "^"]}]}], ")"}]}], 
          RowBox[{"2", 
           RowBox[{"\[Pi]", "(", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"x", "-", "a"}], ")"}], "2"], "+", 
             SuperscriptBox["y", "2"]}], ")"}]}]]}],
        TraditionalForm], ")"}]}], "=", " ", 
     RowBox[{
      FractionBox[
       RowBox[{
        SubscriptBox["q", "0"], "\[Gamma]"}], 
       RowBox[{"2", "\[Pi]"}]], 
      RowBox[{"(", 
       RowBox[{"(", 
        RowBox[{
         FormBox[
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              FractionBox[
               RowBox[{"  ", "x"}], 
               RowBox[{
                SuperscriptBox["x", "2"], "+", 
                SuperscriptBox["y", "2"]}]], "+", 
              FractionBox[
               RowBox[{"x", "-", "a"}], 
               RowBox[{
                SuperscriptBox[
                 RowBox[{"(", 
                  RowBox[{"x", "-", "a"}], ")"}], "2"], "+", 
                SuperscriptBox["y", "2"]}]]}], ")"}], 
            OverscriptBox["x", "^"]}], " ", "+", 
           RowBox[{"(", 
            RowBox[{
             FractionBox["y", 
              RowBox[{
               SuperscriptBox["x", "2"], "+", 
               SuperscriptBox["y", "2"]}]], "+", " ", 
             FractionBox[
              RowBox[{"y", " "}], 
              RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                 RowBox[{"x", "-", "a"}], ")"}], "2"], "+", 
               SuperscriptBox["y", "2"]}]]}], ")"}]}],
          TraditionalForm], 
         OverscriptBox["y", "^"]}], ")"}], ")"}]}]}]}]}], "\[IndentingNewLine]", 
  RowBox[{
   SubscriptBox[
    RowBox[{
     OverscriptBox["B", "\[Rule]"], "'"}], "T"], "=", " ", 
   RowBox[{
    FractionBox[
     RowBox[{
      SubscriptBox["q", "0"], "\[Gamma]V"}], 
     RowBox[{"2", "\[Pi]"}]], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
