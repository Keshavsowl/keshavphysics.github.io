Cell[TextData[{
 "For checking whether or not Lagrangian is gauge invariant or not we have to \
see that Lagrangian before gauge transformation and Lagrangian gauge \
transformation.\nLagrangian before gauge transformation \n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{"L", "(", "x", ")"}], "=", " ", 
    RowBox[{
     RowBox[{
      FractionBox["1", "4"], 
      SubscriptBox["F", "\[Mu]\[Nu]"], 
      SuperscriptBox["F", "\[Mu]\[Nu]"]}], " ", "-", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{
       SubscriptBox["F", "\[Mu]\[Nu]"], "(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[PartialD]", "\[Mu]"], 
         SuperscriptBox["A", "\[Vee]"]}], " ", "-", " ", 
        RowBox[{
         SuperscriptBox["\[PartialD]", "\[Nu]"], 
         SuperscriptBox["A", "\[Mu]"]}]}], ")"}]}], " ", "+", " ", 
     RowBox[{
      FractionBox["1", "2"], 
      SuperscriptBox["m", "2"], 
      SuperscriptBox["A", "\[Mu]"], 
      SubscriptBox["A", "\[Mu]"]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "From", " ", "the", " ", "frist", " ", "part", " ", "we", " ", "can", " ", 
    "write", " ", "the", " ", "lagragin", " ", "in", " ", "the", " ", 
    "form"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"L", "(", "x", ")"}], "=", " ", 
    RowBox[{
     RowBox[{
      FractionBox["1", "4"], 
      SubscriptBox["F", "\[Mu]\[Nu]"], 
      SuperscriptBox["F", "\[Mu]\[Nu]"]}], " ", "-", 
     RowBox[{
      FractionBox["1", "2"], 
      SubscriptBox["F", "\[Mu]\[Nu]"], 
      SuperscriptBox["F", 
       RowBox[{"\[Mu]", "\[Vee]"}]]}], " ", "+", " ", 
     RowBox[{
      FractionBox["1", "2"], 
      SuperscriptBox["m", "2"], 
      SuperscriptBox["A", "\[Mu]"], 
      SubscriptBox["A", "\[Mu]"], "         "}]}]}], TraditionalForm]}],
  ExpressionUUID->"06787c98-60f9-4a4f-b82f-6b90d66984f2"],
 "\n\nLet us us now see the lagrange after gauge transformation denoted by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "'"}], TraditionalForm]],ExpressionUUID->
  "dc8d3e90-684f-9840-aad7-e5e64606d7ad"],
 "\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{"L", "'"}], "=", 
    RowBox[{
     RowBox[{"(", " ", 
      RowBox[{
       RowBox[{
        FractionBox["1", "4"], 
        SubscriptBox["F", "\[Mu]\[Nu]"], 
        SuperscriptBox["F", "\[Mu]\[Nu]"]}], " ", "-", 
       RowBox[{
        FractionBox["1", "2"], 
        SubscriptBox["F", "\[Mu]\[Nu]"], 
        SuperscriptBox["F", 
         RowBox[{"\[Mu]", "\[Vee]"}]]}], "+", " ", 
       RowBox[{
        FractionBox["1", "2"], 
        SuperscriptBox["m", "2"], 
        SuperscriptBox["A", "\[Mu]"], 
        SubscriptBox["A", "\[Mu]"]}]}], ")"}], "'"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Let", " ", "us", " ", "see", " ", "now", " ", "how", " ", "each", " ", 
    "component", " ", "is", " ", "transforming"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"F", "'"}], 
     RowBox[{"\[Mu]", "\[Vee]"}]], " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["\[PartialD]", "\[Mu]"], 
       SuperscriptBox[
        RowBox[{"A", "'"}], "\[Vee]"]}], " ", "-", " ", 
      RowBox[{
       SuperscriptBox["\[PartialD]", "\[Nu]"], 
       SuperscriptBox[
        RowBox[{"A", "'"}], "\[Mu]"]}]}], "  ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["\[PartialD]", "\[Mu]"], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["A", "\[Vee]"], " ", "+", " ", 
          RowBox[{
           SuperscriptBox["\[PartialD]", "\[Vee]"], "\[CapitalLambda]"}]}], 
         ")"}]}], "-", 
       RowBox[{
        SuperscriptBox["\[PartialD]", "\[Nu]"], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["A", "\[Mu]"], " ", "+", " ", 
          RowBox[{
           SuperscriptBox["\[PartialD]", "\[Mu]"], "\[CapitalLambda]"}]}], 
         ")"}]}]}], "=", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{
         SuperscriptBox["\[PartialD]", "\[Mu]"], 
         SuperscriptBox["A", "\[Vee]"]}], " ", "+", " ", 
        RowBox[{
         SuperscriptBox["\[PartialD]", "\[Mu]"], 
         RowBox[{
          SuperscriptBox["\[PartialD]", "\[Vee]"], "\[CapitalLambda]"}]}], "-", 
        RowBox[{
         SuperscriptBox["\[PartialD]", "\[Nu]"], 
         SuperscriptBox["A", "\[Mu]"]}], " ", "-", 
        RowBox[{
         SuperscriptBox["\[PartialD]", "\[Nu]"], " ", 
         RowBox[{
          SuperscriptBox["\[PartialD]", "\[Mu]"], "\[CapitalLambda]"}]}]}], 
       " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{
          SuperscriptBox["\[PartialD]", "\[Mu]"], 
          SuperscriptBox["A", "\[Vee]"]}], "-", 
         RowBox[{
          SuperscriptBox["\[PartialD]", "\[Nu]"], 
          SuperscriptBox["A", "\[Mu]"]}]}], " ", "=", " ", 
        SuperscriptBox["F", "\[Mu]\[Nu]"]}]}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"Let", " ", "us", " ", "now", " ", "see", "  ", 
     SuperscriptBox[
      RowBox[{"A", "'"}], "\[Mu]"], 
     SubscriptBox[
      RowBox[{"A", "'"}], "\[Mu]"]}], " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["A", "\[Mu]"], " ", "+", " ", 
        RowBox[{
         SuperscriptBox["\[PartialD]", "\[Mu]"], "\[CapitalLambda]"}]}], 
       ")"}], 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["A", "\[Mu]"], " ", "+", " ", 
        RowBox[{
         SubscriptBox["\[PartialD]", "\[Mu]"], "\[CapitalLambda]"}]}], 
       ")"}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["A", "\[Mu]"], " ", 
        SubscriptBox["A", "\[Mu]"]}], " ", "+", " ", 
       RowBox[{
        SuperscriptBox["A", "\[Mu]"], 
        RowBox[{
         SubscriptBox["\[PartialD]", "\[Mu]"], "\[CapitalLambda]"}]}], "+", 
       " ", 
       RowBox[{
        SubscriptBox["A", "\[Mu]"], 
        RowBox[{
         SuperscriptBox["\[PartialD]", "\[Mu]"], "\[CapitalLambda]"}]}], " ", 
       "+", " ", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[PartialD]", "\[Mu]"], "\[CapitalLambda]"}], " ", 
        RowBox[{
         SubscriptBox["\[PartialD]", "\[Mu]"], "\[CapitalLambda]"}]}]}], "  ",
       "\[NotEqual]", " ", 
      RowBox[{
       SuperscriptBox["A", "\[Mu]"], " ", 
       SubscriptBox["A", "\[Mu]"]}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"Hence", " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"L", "'"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox["1", "4"], 
       SubscriptBox[
        RowBox[{"F", "'"}], "\[Mu]\[Nu]"], 
       SuperscriptBox[
        RowBox[{"F", "'"}], "\[Mu]\[Nu]"]}], " ", "-", 
      RowBox[{
       FractionBox["1", "2"], 
       SubscriptBox[
        RowBox[{"F", "'"}], "\[Mu]\[Nu]"], 
       SuperscriptBox[
        RowBox[{"F", "'"}], 
        RowBox[{"\[Mu]", "\[Vee]"}]]}], "+", " ", 
      RowBox[{
       FractionBox["1", "2"], 
       SuperscriptBox["m", "2"], 
       SuperscriptBox[
        RowBox[{"A", "'"}], "\[Mu]"], 
       SubscriptBox[
        RowBox[{"A", "'"}], "\[Mu]"]}]}], " ", "=", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        FractionBox["1", "4"], 
        SubscriptBox["F", "\[Mu]\[Nu]"], 
