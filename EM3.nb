    RowBox[{"\[Gamma]", "(", 
     RowBox[{
      OverscriptBox["v", "\[Rule]"], "\[Times]", 
      OverscriptBox["B", "\[Rule]"]}], ")"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{
      OverscriptBox["B", "\[Rule]"], "'"}], "\[Perpendicular]"], " ", "=", 
