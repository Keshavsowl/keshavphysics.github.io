            SuperscriptBox["z", "2"]}]]], 
         OverscriptBox["y", "^"]}], ")"}]}]}]}], "\[IndentingNewLine]", 
    "\[IndentingNewLine]"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
    "As", " ", "we", " ", "are", " ", "now", " ", "in", " ", "the", " ", 
     "primed", " ", "frame", " ", "hence", " ", "we", " ", "can", " ", 
     "write", " ", "x"}], ",", "y", ",", 
    RowBox[{"z", " ", "in", " ", "terms", " ", "of", " ", 
     RowBox[{"x", "'"}]}], ",", 
