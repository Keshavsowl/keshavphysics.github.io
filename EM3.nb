       OverscriptBox["E", "\[Rule]"]}]}], ")"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Hence", " ", "for", " ", "the", " ", "obersever", " ", "moving", " ", 
    "along", " ", "the", " ", "wire", " ", "the", " ", "components", " ", 
    "of", " ", "the", " ", "fields", " ", "are"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{
      OverscriptBox["E", "\[Rule]"], "'"}], "||"], " ", "=", " ", 
    SubscriptBox[
     OverscriptBox["E", "\[Rule]"], "||"]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{
      OverscriptBox["B", "\[Rule]"], "'"}], "||"], " ", "=", " ", 
    SubscriptBox[
     OverscriptBox["B", "\[Rule]"], "||"]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{
      OverscriptBox["E", "\[Rule]"], "'"}], "\[Perpendicular]"], " ", "=", 
    " ", 
    RowBox[{"\[Gamma]", "(", 
     RowBox[{
      SubscriptBox[
       OverscriptBox["E", "\[Rule]"], "\[Perpendicular]"], "+", 
      RowBox[{
       OverscriptBox["v", "\[Rule]"], "\[Times]", 
       OverscriptBox["B", "\[Rule]"]}]}], ")"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{
      OverscriptBox["B", "\[Rule]"], "'"}], "\[Perpendicular]"], " ", "=", 
    " ", 
    RowBox[{"\[Gamma]", "(", 
     RowBox[{
      SubscriptBox[
       OverscriptBox["B", "\[Rule]"], "\[Perpendicular]"], "-", 
      RowBox[{
       OverscriptBox["v", "\[Rule]"], "\[Times]", 
       OverscriptBox["E", "\[Rule]"]}]}], ")"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"In", " ", "the", " ", "lab", " ", "frame", "  ", 
     OverscriptBox["E", "\[Rule]"]}], " ", "=", " ", 
    RowBox[{
    "0", " ", "hence", "  ", "and", " ", "parallel", " ", "componet", " ", 
     "of", " ", "Magnetic", " ", "field", " ", "is", " ", "also", " ", 
     "zero"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{
      OverscriptBox["E", "\[Rule]"], "'"}], "||"], " ", "=", " ", 
    RowBox[{
     SubscriptBox[
      OverscriptBox["E", "\[Rule]"], "||"], " ", "=", " ", "0"}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{
