        FractionBox[
         RowBox[{"-", "B\[Gamma]v"}], "c"], "B\[Gamma]", "0", "0"}
      }], ")"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Therefore", " ", "this", " ", "is", " ", "tensor", " ", "which", " ", 
    "looks", " ", "in", " ", "the", " ", "like", " ", "in", " ", "our", " ", 
