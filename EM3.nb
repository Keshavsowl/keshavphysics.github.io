  3.968360789775917*^9}},ExpressionUUID->"1798e291-f81b-6749-9572-\
073e69d36747"],

Cell[TextData[{
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"From", " ", "Gauss", " ", "Law"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       OverscriptBox["\[Del]", "\[Rule]"], ".", 
       OverscriptBox["E", 
        RowBox[{"\[Rule]", " "}]]}], "  ", "=", " ", 
      FractionBox["\[Rho]", 
       SubscriptBox["\[Epsilon]", "0"]]}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       OverscriptBox["\[Del]", "\[Rule]"], ".", 
       OverscriptBox["E", 
        RowBox[{"\[Rule]", " "}]]}], " ", "=", " ", 
      RowBox[{
       OverscriptBox[
        RowBox[{"\[Del]", ".", "("}], "\[Rule]"], "-", " ", 
       RowBox[{"\[Gamma]", " ", "v", " ", 
        FractionBox[
         RowBox[{
          SubscriptBox["\[Mu]", "0"], "I", " ", "r"}], 
         RowBox[{"2", "\[Pi]", " ", 
          SuperscriptBox[
           SubscriptBox["r", "0"], "2"]}]], " ", 
        OverscriptBox["r", "^"]}]}]}]}], " ", ")"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
    "As", " ", "there", " ", "is", " ", "only", " ", "r", " ", "dependence", " ",
      "on", " ", "the", " ", "electric", " ", "field"}], " "}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"  ", 
    RowBox[{"\[Rho]", "=", "  ", 
     RowBox[{"\[Gamma]", " ", "v", " ", 
      FractionBox[
       RowBox[{
        SubscriptBox["\[Epsilon]", "0"], 
        SubscriptBox["\[Mu]", "0"], "I", " "}], 
       RowBox[{"2", "\[Pi]", " ", 
        SuperscriptBox[
         SubscriptBox["r", "0"], "2"]}]], " "}]}]}], TraditionalForm]}],
  ExpressionUUID->"6a0d3626-3ad9-644d-9a4a-673fc0ad2160"],
 "\n"
}], "Text",
