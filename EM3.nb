Cell[TextData[{
 "Working in the units where c= 1\nWe know that for transformation of \
Electric field\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    OverscriptBox[
     RowBox[{"E", "'"}], "\[Rule]"], " ", "=", " ", 
    RowBox[{
     RowBox[{"\[Gamma]", "(", 
      RowBox[{
       OverscriptBox["E", "\[Rule]"], "  ", "+", " ", 
       RowBox[{
        OverscriptBox["v", "\[Rule]"], "\[Times]", " ", 
        OverscriptBox["B", "\[Rule]"]}]}], ")"}], " ", "-", " ", 
     RowBox[{
      FractionBox[
       RowBox[{"(", 
        RowBox[{"\[Gamma]", "-", "1"}], ")"}], 
       SuperscriptBox["v", "2"]], 
      RowBox[{"(", 
       RowBox[{
        OverscriptBox["v", "->"], " ", ".", 
        OverscriptBox["E", "\[Rule]"]}], ")"}], 
      OverscriptBox["v", "\[Rule]"]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox[
      RowBox[{"B", "'"}], "\[Rule]"], " ", "=", " ", 
     RowBox[{
      RowBox[{"\[Gamma]", "(", 
       RowBox[{
        RowBox[{
         OverscriptBox["v", "\[Rule]"], "\[Times]", " ", 
         OverscriptBox["E", "\[Rule]"]}], " ", "-", " ", 
        OverscriptBox["E", "\[Rule]"]}], ")"}], " ", "-", " ", 
      RowBox[{
       FractionBox[
        RowBox[{"(", 
         RowBox[{"\[Gamma]", "-", "1"}], ")"}], 
        SuperscriptBox["v", "2"]], 
       RowBox[{"(", 
        RowBox[{
         OverscriptBox["v", "->"], " ", ".", 
         OverscriptBox["B", "\[Rule]"]}], ")"}], 
       OverscriptBox["v", "\[Rule]"]}]}]}], "\[IndentingNewLine]"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "It", " ", "is", " ", "given", " ", "that", " ", "observer", " ", "is", " ",
     "moving", " ", "in", " ", "x", " ", "direction", " ", "with", " ", 
    "boost", " ", "v"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Hence", " ", "the", " ", "Transformation", " ", "will", " ", "further", " ",
     "reduce", " ", "to"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"E", "'"}], "x"], " ", "=", " ", 
    RowBox[{
     RowBox[{
      SubscriptBox["E", "x"], "                                                               ", 
      SubscriptBox[
       RowBox[{"B", "'"}], "x"]}], " ", "=", " ", 
     SubscriptBox["B", "x"]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"E", "'"}], "y"], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Gamma]", "(", 
        RowBox[{
         SubscriptBox["E", "y"], " ", "-", 
         SubscriptBox["vB", "z"]}], ")"}], "                                        ", 
       SubscriptBox[
        RowBox[{"B", "'"}], "y"]}], "  ", "=", " ", 
      RowBox[{"\[Gamma]", "(", 
       RowBox[{
        SubscriptBox["B", "y"], " ", "+", 
        SubscriptBox["vE", "z"]}], ")"}]}]}], " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"E", "'"}], "z"], " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Gamma]", "(", 
       RowBox[{
        SubscriptBox["E", "z"], " ", "+", 
        SubscriptBox["vB", "y"]}], ")"}], "                                        ", 
      SubscriptBox[
       RowBox[{"B", "'"}], "z"]}], " ", "=", " ", 
     RowBox[{"\[Gamma]", "(", 
      RowBox[{
       SubscriptBox["B", "z"], " ", "-", 
       SubscriptBox["vE", "y"]}], ")"}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"In", " ", "the", " ", "rest", " ", "frame", "  ", 
      SubscriptBox["E", "x"]}], " ", "=", " ", 
     RowBox[{
      FractionBox["Q", 
       SqrtBox[
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox["z", "2"]}]]], 
      OverscriptBox["x", "^"]}]}], " ", ",", "   ", 
    RowBox[{
     SubscriptBox["E", "y"], " ", "=", " ", 
     RowBox[{
      FractionBox["Q", 
       SqrtBox[
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox["z", "2"]}]]], 
      OverscriptBox["y", "^"]}]}], ",", "    ", 
    RowBox[{
     SubscriptBox["E", "z"], " ", "=", " ", 
     RowBox[{
      FractionBox["Q", 
       SqrtBox[
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox["z", "2"]}]]], 
      OverscriptBox["z", "^"]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"                                           ", 
    RowBox[{
     RowBox[{
      SubscriptBox["B", "x"], "=", "0"}], " ", ",", "  ", 
     RowBox[{
      SubscriptBox["B", "y"], "=", "0"}], ",", "  ", 
     RowBox[{
      SubscriptBox["B", "z"], "=", "0"}]}], "\[IndentingNewLine]"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
    "Hence", " ", "component", " ", "of", " ", "elctric", " ", "and", " ", 
     "magnetic", " ", "field", " ", "in", " ", "the", " ", "primed", " ", 
     "frame"}], " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"E", "'"}], "x"], " ", "=", "  ", 
     RowBox[{
      SubscriptBox["E", "x"], " ", "=", " ", 
      RowBox[{
       FractionBox["Q", 
        SqrtBox[
         RowBox[{
          SuperscriptBox["x", "2"], "+", 
          SuperscriptBox["y", "2"], "+", 
          SuperscriptBox["z", "2"]}]]], 
       OverscriptBox["x", "^"]}]}]}], 
    "                                               "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"E", "'"}], "y"], "  ", "=", " ", 
     RowBox[{
      RowBox[{"\[Gamma]", "(", 
       RowBox[{
        SubscriptBox["E", "y"], " ", "-", 
        SubscriptBox["vB", "z"]}], ")"}], " ", "=", " ", 
      RowBox[{"\[Gamma]", 
       FractionBox["Q", 
        SqrtBox[
         RowBox[{
          SuperscriptBox["x", "2"], "+", 
          SuperscriptBox["y", "2"], "+", 
          SuperscriptBox["z", "2"]}]]], 
       OverscriptBox["y", "^"]}]}]}], " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"E", "'"}], "z"], " ", "=", " ", 
    RowBox[{
     RowBox[{"\[Gamma]", "(", 
      RowBox[{
       SubscriptBox["E", "z"], " ", "+", 
       SubscriptBox["vB", "y"]}], ")"}], "    ", "=", " ", 
     RowBox[{
      SubscriptBox[
       RowBox[{"E", "'"}], "z"], " ", "=", " ", 
      RowBox[{"\[Gamma]", " ", 
       FractionBox["Q", 
        SqrtBox[
         RowBox[{
          SuperscriptBox["x", "2"], "+", 
          SuperscriptBox["y", "2"], "+", 
          SuperscriptBox["z", "2"]}]]], 
       OverscriptBox["z", "^"]}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"B", "'"}], "x"], " ", "=", " ", 
    RowBox[{
     SubscriptBox["B", "x"], " ", "=", " ", "0"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"B", "'"}], "y"], "  ", "=", " ", 
    RowBox[{
     RowBox[{"\[Gamma]", "(", 
      RowBox[{
       SubscriptBox["B", "y"], " ", "+", 
       SubscriptBox["vE", "z"]}], ")"}], "  ", "=", " ", 
     RowBox[{"\[Gamma]", "(", " ", 
      RowBox[{"v", " ", 
       FractionBox["Q", 
        SqrtBox[
         RowBox[{
          SuperscriptBox["x", "2"], "+", 
          SuperscriptBox["y", "2"], "+", 
          SuperscriptBox["z", "2"]}]]], 
       OverscriptBox["z", "^"]}], ")"}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"B", "'"}], "z"], "   ", "=", " ", 
     RowBox[{
      RowBox[{"\[Gamma]", "(", 
       RowBox[{
        SubscriptBox["B", "z"], " ", "-", 
        SubscriptBox["vE", "y"]}], ")"}], "   ", "=", " ", 
      RowBox[{"-", 
       RowBox[{"\[Gamma]", "(", 
        RowBox[{"v", " ", 
         FractionBox["Q", 
          SqrtBox[
           RowBox[{
            SuperscriptBox["x", "2"], "+", 
