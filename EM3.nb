     SubscriptBox[
      OverscriptBox["B", "\[Rule]"], "||"], " ", "=", " ", "0"}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
