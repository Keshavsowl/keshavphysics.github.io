       RowBox[{"(", 
        RowBox[{"\[Gamma]", "-", "1"}], ")"}], 
       SuperscriptBox["v", "2"]], 
      RowBox[{"(", 
       RowBox[{
        OverscriptBox["v", "->"], " ", ".", 
        SubscriptBox[
         OverscriptBox["E", "\[Rule]"], "||"]}], ")"}], 
      OverscriptBox["v", "\[Rule]"]}], " ", "-", " ", 
     RowBox[{
      FractionBox[
       RowBox[{"(", 
        RowBox[{"\[Gamma]", "-", "1"}], ")"}], 
       SuperscriptBox["v", "2"]], 
      RowBox[{"(", 
       RowBox[{
        OverscriptBox["v", "->"], " ", ".", 
        SubscriptBox[
         OverscriptBox["E", "\[Rule]"], "\[Perpendicular]"]}], ")"}], 
      OverscriptBox["v", "\[Rule]"]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox[
       RowBox[{
        OverscriptBox["E", "\[Rule]"], "'"}], "||"], " ", "+", " ", 
      SubscriptBox[
       RowBox[{
        OverscriptBox["E", "\[Rule]"], "'"}], "\[Perpendicular]"]}], " ", "=",
      " ", 
     RowBox[{
      RowBox[{"\[Gamma]", 
       SubscriptBox[
        OverscriptBox["E", "\[Rule]"], "||"]}], " ", "+", " ", 
      RowBox[{"\[Gamma]", " ", 
       SubscriptBox[
        OverscriptBox["E", "\[Rule]"], "\[Perpendicular]"]}], 
      StyleBox["+",
       FontWeight->"Bold"], 
      StyleBox[" ",
       FontWeight->"Bold"], 
      RowBox[{
       StyleBox["\[Gamma]",
        FontWeight->"Bold"], " ", 
       OverscriptBox["v", "\[Rule]"], " ", "\[Times]", " ", 
       OverscriptBox["B", "\[Rule]"]}], " ", "-", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Gamma]", "-", "1"}], ")"}], " ", 
       SubscriptBox[
        OverscriptBox["E", "\[Rule]"], "||"]}]}]}], " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"Hence", " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{
       OverscriptBox["E", "\[Rule]"], "'"}], "||"], "  ", "=", "  ", 
     SubscriptBox[
      OverscriptBox["E", "\[Rule]"], "||"]}], " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{
       OverscriptBox["E", "\[Rule]"], "'"}], "\[Perpendicular]"], " ", "=", 
     "  ", 
     RowBox[{
      RowBox[{"\[Gamma]", " ", 
       SubscriptBox[
        OverscriptBox["E", "\[Rule]"], "\[Perpendicular]"]}], 
      StyleBox["+",
       FontWeight->"Bold"], " ", 
      RowBox[{"\[Gamma]", 
       OverscriptBox["v", "\[Rule]"], " ", "\[Times]", " ", 
       OverscriptBox["B", "\[Rule]"]}]}]}], " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Similarly", " ", "by", " ", "symmetric", " ", "calculation", " ", "for", " ",
     "the", " ", "magnetic", "  ", "field"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{
       OverscriptBox["B", "\[Rule]"], "'"}], "||"], "  ", "=", "  ", 
     SubscriptBox[
      OverscriptBox["B", "\[Rule]"], "||"]}], " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{
       OverscriptBox["B", "\[Rule]"], "'"}], "\[Perpendicular]"], " ", "=", 
