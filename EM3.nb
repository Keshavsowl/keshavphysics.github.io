Cell[TextData[{
 "Magnetic field for the conductor is given by the Ampere formulas by\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    OverscriptBox["B", "\[Rule]"], "=", 
    RowBox[{"{", GridBox[{
       {
        FractionBox[
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["\[Mu]", "0"], "I"}], ")"}], 
         RowBox[{"2", "\[Pi]", " ", "r"}]], 
        RowBox[{"r", ">", 
         SubscriptBox["r", "0"]}]},
       {
        FractionBox[
         RowBox[{
          SubscriptBox["\[Mu]", "0"], "I", " ", "r"}], 
         RowBox[{"2", "\[Pi]", " ", 
          SuperscriptBox[
           SubscriptBox["r", "0"], "2"]}]], 
        RowBox[{"r", " ", "<", " ", 
         SubscriptBox["r", "0"]}]}
      }], " ", "}"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
     "Electric", " ", "field", " ", "in", " ", "the", " ", "lab", " ", 
      "frame", " ", 
      OverscriptBox["E", "\[Rule]"]}], "=", " ", "0"}], 
    "\[IndentingNewLine]"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Transformation", " ", "rules", " ", "for", " ", "electric", " ", "and", " ",
     "Magnetic", " ", "field", " ", "is"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    OverscriptBox[
     RowBox[{"E", "'"}], "\[Rule]"], " ", "=", " ", 
    RowBox[{
     RowBox[{"\[Gamma]", "(", 
      RowBox[{
       OverscriptBox["E", "\[Rule]"], "  ", "+", " ", 
       RowBox[{
        OverscriptBox["v", "\[Rule]"], "\[Times]", " ", 
        OverscriptBox["B", "\[Rule]"]}]}], ")"}], " ", "-", " ", 
     RowBox[{
      FractionBox[
       RowBox[{"(", 
        RowBox[{"\[Gamma]", "-", "1"}], ")"}], 
       SuperscriptBox["v", "2"]], 
      RowBox[{"(", 
       RowBox[{
        OverscriptBox["v", "->"], " ", ".", 
        OverscriptBox["E", "\[Rule]"]}], ")"}], 
      OverscriptBox["v", "\[Rule]"]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox[
      RowBox[{"B", "'"}], "\[Rule]"], " ", "=", " ", 
     RowBox[{
      RowBox[{"\[Gamma]", "(", 
       RowBox[{
        RowBox[{
         OverscriptBox["v", "\[Rule]"], "\[Times]", " ", 
         OverscriptBox["E", "\[Rule]"]}], " ", "-", " ", 
        OverscriptBox["E", "\[Rule]"]}], ")"}], " ", "-", " ", 
      RowBox[{
       FractionBox[
        RowBox[{"(", 
         RowBox[{"\[Gamma]", "-", "1"}], ")"}], 
        SuperscriptBox["v", "2"]], 
       RowBox[{"(", 
        RowBox[{
         OverscriptBox["v", "->"], " ", ".", 
         OverscriptBox["B", "\[Rule]"]}], ")"}], 
       OverscriptBox["v", "\[Rule]"]}]}]}], " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Let", " ", "us", " ", "decopose", " ", "this", " ", "into", " ", 
    "parallel", " ", "and", " ", "perpendicular", " ", "electric", " ", 
    "field"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    OverscriptBox["E", "\[Rule]"], " ", "=", " ", 
    RowBox[{
     RowBox[{
      SubscriptBox[
       OverscriptBox["E", "\[Rule]"], "||"], "+", " ", 
      RowBox[{
       SubscriptBox[
        OverscriptBox["E", "\[Rule]"], "\[Perpendicular]"], " ", "where", "  ", 
       SubscriptBox[
        OverscriptBox["E", "\[Rule]"], "||"]}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         OverscriptBox["E", "\[Rule]"], ".", 
         OverscriptBox["v", "^"]}], ")"}], 
       OverscriptBox["v", "^"]}], " ", "=", "  ", 
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          OverscriptBox["E", "\[Rule]"], ".", 
          OverscriptBox["v", "\[Rule]"]}], ")"}], 
        OverscriptBox["v", "\[Rule]"], " "}], 
       SuperscriptBox["v", "2"]]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{
       OverscriptBox["E", "\[Rule]"], "'"}], "||"], " ", "+", " ", 
     SubscriptBox[
      RowBox[{
       OverscriptBox["E", "\[Rule]"], "'"}], "\[Perpendicular]"]}], "=", " ", 
    RowBox[{
     RowBox[{"\[Gamma]", " ", 
      SubscriptBox[
       OverscriptBox["E", "\[Rule]"], "||"]}], " ", "+", " ", 
     RowBox[{"\[Gamma]", " ", 
      SubscriptBox[
       OverscriptBox["E", "\[Rule]"], "\[Perpendicular]"]}], 
     StyleBox[" ",
      FontWeight->"Bold"], 
     StyleBox["+",
      FontWeight->"Bold"], 
     StyleBox[" ",
      FontWeight->"Bold"], 
     RowBox[{
      StyleBox["\[Gamma]",
       FontWeight->"Bold"], 
      StyleBox[" ",
       FontWeight->"Bold"], 
