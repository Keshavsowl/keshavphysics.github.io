    RowBox[{"\[Gamma]", "(", 
     SubscriptBox[
      OverscriptBox["B", "\[Rule]"], "\[Perpendicular]"], ")"}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"Using", " ", "the", "  ", 
     OverscriptBox["v", "\[Rule]"], "\[Times]", 
     OverscriptBox["B", "\[Rule]"]}], " ", "=", " ", 
    RowBox[{
     RowBox[{"v", " ", 
      OverscriptBox["k", "^"], " ", "\[Times]", 
      SubscriptBox["B", "\[Phi]"], 
      OverscriptBox["\[Phi]", "^"]}], " ", "=", " ", 
     RowBox[{
      RowBox[{"-", "v"}], " ", 
      SubscriptBox["B", "\[Phi]"], 
      OverscriptBox["r", "^"]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox["B", "\[Rule]"], "\[Perpendicular]"], " ", "=", " ", 
     RowBox[{
      OverscriptBox["B", "\[Rule]"], " ", "=", " ", 
      RowBox[{
       SubscriptBox["B", "\[Phi]"], 
       OverscriptBox["\[Phi]", "^"]}]}]}], "\[IndentingNewLine]", 
    "\[IndentingNewLine]"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
    "Hence", " ", "the", " ", "electric", " ", "field", " ", "in", " ", "the",
      " ", "primed", " ", "frame", " ", "is"}], " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["E", "\[Rule]"], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"-", " ", "\[Gamma]"}], " ", "v", " ", 
       SubscriptBox["B", "\[Phi]"], 
       OverscriptBox["r", "^"]}], " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"-", " ", "\[Gamma]"}], " ", "v", " ", 
        FractionBox[
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["\[Mu]", "0"], "I"}], ")"}], 
         RowBox[{"2", "\[Pi]", " ", "r"}]], " ", 
        OverscriptBox["r", "^"], "  ", "and", "   ", 
        OverscriptBox["B", "\[Rule]"]}], " ", "=", " ", 
       RowBox[{
        RowBox[{
         SubscriptBox["B", "\[Phi]"], 
         OverscriptBox["\[Phi]", "^"]}], " ", "=", " ", 
        RowBox[{
         RowBox[{
          FractionBox[
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["\[Mu]", "0"], "I"}], ")"}], 
           RowBox[{"2", "\[Pi]", " ", "r"}]], 
          OverscriptBox["\[Phi]", "^"], "      ", "for", " ", "r"}], "  ", ">",
          " ", 
         SubscriptBox["r", "0"]}]}]}]}]}], "\[IndentingNewLine]"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    OverscriptBox["E", "\[Rule]"], " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"-", " ", "\[Gamma]"}], " ", "v", " ", 
      SubscriptBox["B", "\[Phi]"], 
      OverscriptBox["r", "^"]}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"-", " ", "\[Gamma]"}], " ", "v", " ", 
       FractionBox[
        RowBox[{
         SubscriptBox["\[Mu]", "0"], "I", " ", "r"}], 
        RowBox[{"2", "\[Pi]", " ", 
         SuperscriptBox[
          SubscriptBox["r", "0"], "2"]}]], " ", 
       OverscriptBox["r", "^"], "  ", "and", "   ", 
       OverscriptBox["B", "\[Rule]"]}], " ", "=", " ", 
      RowBox[{
       RowBox[{
        SubscriptBox["B", "\[Phi]"], 
        OverscriptBox["\[Phi]", "^"]}], " ", "=", " ", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{
           SubscriptBox["\[Mu]", "0"], "I", " ", "r"}], 
          RowBox[{"2", "\[Pi]", " ", 
           SuperscriptBox[
            SubscriptBox["r", "0"], "2"]}]], 
         OverscriptBox["\[Phi]", "^"], "       ", "for", " ", "r"}], " ", "<",
         " ", 
        SubscriptBox["r", "0"]}]}]}]}]}], TraditionalForm]}],
  FormatType->TraditionalForm,ExpressionUUID->
  "e5e2508e-0c14-1945-864c-3406d33e15cb"]
}], "Text",
