  ExpressionUUID->"e44c8da6-d460-c14f-832d-f50887e713e1"],
 " = \[Gamma] =  ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    SqrtBox[
     RowBox[{"1", "-", " ", 
      RowBox[{
       SuperscriptBox["v", "2"], "/", 
