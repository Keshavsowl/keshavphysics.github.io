Cell[CellGroupData[{

Cell["Question 3", "Section",
 CellChangeTimes->{{3.967567270927206*^9, 
  3.9675673113747673`*^9}},ExpressionUUID->"2e96737f-fd5b-d041-9777-\
461a2ccb349a"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"\[Epsilon]", "'"}], "\[Mu]\[Nu]\[Lambda]\[Rho]"], "=", " ", 
    RowBox[{
     FractionBox[
      RowBox[{"\[PartialD]", 
       SuperscriptBox["x", "\[Alpha]"]}], 
      RowBox[{"\[PartialD]", 
       SuperscriptBox[
        RowBox[{"x", "'"}], "\[Mu]"]}]], " ", 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SuperscriptBox["x", "\[Beta]"]}], 
      RowBox[{"\[PartialD]", 
       SuperscriptBox[
        RowBox[{"x", "'"}], "\[Nu]"]}]], " ", 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SuperscriptBox["x", "\[Gamma]"]}], 
      RowBox[{"\[PartialD]", 
       SuperscriptBox[
        RowBox[{"x", "'"}], "\[Lambda]"]}]], " ", 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SuperscriptBox["x", "\[Delta]"]}], 
      RowBox[{"\[PartialD]", 
       SuperscriptBox[
        RowBox[{"x", "'"}], "\[Rho]"]}]], 
     SubscriptBox["\[Epsilon]", "\[Alpha]\[Beta]\[Gamma]\[Delta]"]}]}], 
   TraditionalForm]],ExpressionUUID->"04c810eb-fc83-c540-9967-7dc9a9996124"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Epsilon]", "\[Mu]\[Nu]\[Lambda]\[Rho]"], TraditionalForm]],
  ExpressionUUID->"9010a51e-43f9-2948-b52c-54f3ac0b7418"],
 " is antisymmetric under the exchange of any two indices and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Epsilon]", "0123"], TraditionalForm]],ExpressionUUID->
  "35f146e3-0156-504e-8670-8fe9978d9f20"],
 " = 1\nProper Transformation - > Transformation where det(\[CapitalLambda]) \
= +1 and \n\nImproper Transformation - > Transformation where det(\
\[CapitalLambda]) = +1 and \n\n\nFrom the notes we know that \n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SuperscriptBox["x", "\[Alpha]"]}], 
     RowBox[{" ", 
      RowBox[{"\[PartialD]", 
       SuperscriptBox[
        RowBox[{"x", "'"}], "\[Mu]"]}]}]], "=", " ", 
    SuperscriptBox[
     SubscriptBox["\[CapitalLambda]", "\[Mu]"], "\[Alpha]"]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"Hence", " ", 
      SubscriptBox[
       RowBox[{"\[Epsilon]", "'"}], "\[Mu]\[Nu]\[Lambda]\[Rho]"]}], "=", " ", 
     RowBox[{
      FractionBox[
       RowBox[{"\[PartialD]", 
        SuperscriptBox["x", "\[Alpha]"]}], 
       RowBox[{"\[PartialD]", 
        SuperscriptBox[
         RowBox[{"x", "'"}], "\[Mu]"]}]], " ", 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SuperscriptBox["x", "\[Beta]"]}], 
       RowBox[{"\[PartialD]", 
        SuperscriptBox[
         RowBox[{"x", "'"}], "\[Nu]"]}]], " ", 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SuperscriptBox["x", "\[Gamma]"]}], 
       RowBox[{"\[PartialD]", 
        SuperscriptBox[
         RowBox[{"x", "'"}], "\[Lambda]"]}]], " ", 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SuperscriptBox["x", "\[Delta]"]}], 
       RowBox[{"\[PartialD]", 
        SuperscriptBox[
         RowBox[{"x", "'"}], "\[Rho]"]}]], 
      SubscriptBox["\[Epsilon]", "\[Alpha]\[Beta]\[Gamma]\[Delta]"], "  ", 
      "can", " ", "be", " ", "written", " ", "as", " ", "a"}]}], " "}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"\[Epsilon]", "'"}], "\[Mu]\[Nu]\[Lambda]\[Rho]"], " ", "=", " ", 
    RowBox[{
     SuperscriptBox[
      SubscriptBox["\[CapitalLambda]", "\[Mu]"], "\[Alpha]"], " ", 
     SuperscriptBox[
      SubscriptBox["\[CapitalLambda]", "\[Nu]"], "\[Beta]"], 
     SuperscriptBox[
      SubscriptBox["\[CapitalLambda]", "\[Lambda]"], "\[Gamma]"], 
     SuperscriptBox[
      SubscriptBox["\[CapitalLambda]", "\[Rho]"], "\[Delta]"], " ", 
     SubscriptBox["\[Epsilon]", "\[Alpha]\[Beta]\[Gamma]\[Delta]"]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
    "Which", " ", "can", " ", "be", " ", "seen", " ", "that", " ", "above", " ",
      "expression", " ", "is", " ", "equal", " ", "to"}], 
    "                                                                    "}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"\[Epsilon]", "'"}], "\[Mu]\[Nu]\[Lambda]\[Rho]"], " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"det", "(", 
       SuperscriptBox["\[CapitalLambda]", 
        RowBox[{"-", "1"}]], ")"}], " ", 
      SubscriptBox["\[Epsilon]", "\[Mu]\[Nu]\[Lambda]\[Rho]"], "             ",
       "As", " ", "we", " ", "know", " ", "that", "     ", 
      RowBox[{"det", "(", "A", ")"}]}], " ", "=", " ", 
     RowBox[{
      SubscriptBox["\[Epsilon]", "ijk"], 
      SubscriptBox["a", "im"], " ", 
      SubscriptBox["a", "in"], 
      SubscriptBox["a", "io"]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"\[Epsilon]", "'"}], "\[Mu]\[Nu]\[Lambda]\[Rho]"], " ", "=", " ", 
    FractionBox[
     SubscriptBox["\[Epsilon]", "\[Mu]\[Nu]\[Lambda]\[Rho]"], 
     RowBox[{
      RowBox[{"det", "(", "\[CapitalLambda]", ")"}], " "}]]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
     "Hence", " ", "for", " ", "the", " ", "Proper", " ", "tansformation", " ", 
      RowBox[{"det", "(", "\[CapitalLambda]", ")"}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"+", "1"}], " ", "hence", " ", 
       SubscriptBox[
        RowBox[{"\[Epsilon]", "'"}], "\[Mu]\[Nu]\[Lambda]\[Rho]"]}], "  ", "=",
       " ", 
      SubscriptBox["\[Epsilon]", "\[Mu]\[Nu]\[Lambda]\[Rho]"]}]}], " "}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"and", " ", "for", " ", "improper", " ", "transformation", "   ", 
     RowBox[{"det", "(", "\[CapitalLambda]", ")"}]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", " ", "1"}], "  ", "hence", " ", 
      SubscriptBox[
       RowBox[{"\[Epsilon]", "'"}], "\[Mu]\[Nu]\[Lambda]\[Rho]"]}], " ", "=", 
     " ", 
     RowBox[{"-", " ", 
      SubscriptBox["\[Epsilon]", "\[Mu]\[Nu]\[Lambda]\[Rho]"], 
      "\[IndentingNewLine]", "\[IndentingNewLine]"}]}]}], TraditionalForm]}],
  FormatType->TraditionalForm,ExpressionUUID->
