Cell[TextData[{
 "Given that charge is moving non relativistically in a x-y plane of a \
constant magnetic field ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["B", "\[Rule]"], " ", "=", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", "0", ",", 
      RowBox[{"B", " ", 
       OverscriptBox["z", "^"]}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "8dfbc45a-8cf4-0945-883b-5b8e94b30405"],
 " with velocity \n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
   "Let", " ", "us", " ", "firstly", " ", "find", " ", "the", " ", "motion", " ",
     "of", " ", "the", " ", "charged", " ", "particle", " ", "in", " ", 
    "such", " ", "a", " ", "field"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{" ", 
    RowBox[{"Lorentz", " ", "force", " ", "equation", " ", "is"}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SuperscriptBox["f", "\[Mu]"], " ", "=", " ", 
    RowBox[{"e", " ", 
     SuperscriptBox["F", "\[Mu]\[Nu]"], 
     SubscriptBox["U", "\[Vee]"]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
    "spatical", " ", "component", " ", "is", " ", "given", " ", "by"}], " "}],
    TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["f", "i"], " ", "=", " ", 
     RowBox[{
      RowBox[{"e", " ", 
       SuperscriptBox["F", "i\[Nu]"], 
       SubscriptBox["U", "\[Vee]"]}], " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{
         SuperscriptBox["eF", "i0"], 
         SubscriptBox["U", "0"]}], " ", "+", " ", 
        RowBox[{"e", " ", 
         SuperscriptBox["F", "ij"], 
         SubscriptBox["U", "j"]}]}], " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"e", "(", 
          RowBox[{"-", 
           SubscriptBox["E", "i"]}], ")"}], 
         RowBox[{"(", 
          RowBox[{"-", "\[Gamma]"}], ")"}]}], " ", "+", " ", 
        RowBox[{"e", " ", 
         SubscriptBox["\[Epsilon]", "ijk"], " ", 
         SubscriptBox["B", "k"], "\[Gamma]", " ", 
         SubscriptBox["v", "j"]}]}]}]}]}], "  "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
