Cell[TextData[{
 "Total power radiated is given by\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{"P", " ", "=", " ", 
    RowBox[{
     FractionBox["2", "3"], 
     FractionBox[
      SuperscriptBox["e", "2"], 
      SuperscriptBox["m", "2"]], 
     FractionBox[
      SuperscriptBox["dp", "\[Mu]"], "d\[Tau]"], 
     FractionBox[
      SubscriptBox["dp", "\[Mu]"], "d\[Tau]"]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "calcuting", " ", "this", " ", "in", " ", "terms", " ", "of", " ", "the", " ",
     "three", " ", "quanttites", " ", "variables"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"P", " ", "=", " ", 
    RowBox[{
     FractionBox["2", "3"], 
     SuperscriptBox["e", "2"], 
     RowBox[{
      SuperscriptBox["\[Gamma]", "6"], "[", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "-", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          OverscriptBox["v", "\[Rule]"], "\[Times]", 
          OverscriptBox["a", "\[Rule]"]}], ")"}], "2"]}], "]"}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    OverscriptBox["F", "\[Rule]"], " ", "=", " ", 
    RowBox[{"q", " ", 
     OverscriptBox["v", "\[Rule]"], " ", "\[Times]", " ", 
     OverscriptBox["B", "\[Rule]"]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[Gamma]", " ", "m", " ", 
      OverscriptBox["a", "\[Rule]"]}], " ", "=", " ", 
     RowBox[{"q", " ", 
      OverscriptBox["v", "\[Rule]"], " ", "\[Times]", " ", 
      OverscriptBox["B", "\[Rule]"]}]}], "                 "}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[Implies]", "  ", 
      OverscriptBox["a", "\[Rule]"]}], "  ", "=", " ", 
     FractionBox[
      RowBox[{"(", " ", 
       RowBox[{"q", " ", 
        OverscriptBox["v", "\[Rule]"], " ", "\[Times]", " ", 
        OverscriptBox["B", "\[Rule]"]}], "  ", ")"}], 
      RowBox[{"\[Gamma]", " ", "m"}]]}], "   "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"For", " ", "our", " ", "case", " ", 
     OverscriptBox["v", "\[Rule]"]}], " ", "\[Perpendicular]", " ", 
    OverscriptBox["B", "\[Rule]"]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{" ", 
    RowBox[{
     RowBox[{"\[Implies]", " ", "a"}], "  ", "=", " ", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{" ", 
         RowBox[{"q", " ", "v", " ", "B", " "}]}], 
        RowBox[{"\[Gamma]", " ", "m"}]], " ", "\[Implies]", " ", 
       SuperscriptBox["a", "2"]}], " ", "=", 
      FractionBox[
       RowBox[{" ", 
        RowBox[{
         SuperscriptBox["q", "2"], " ", 
         SuperscriptBox["v", "2"], " ", 
         SuperscriptBox["B", "2"], " "}]}], 
       RowBox[{
        SuperscriptBox["\[Gamma]", "2"], " ", 
        SuperscriptBox["m", "2"]}]]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"\[Implies]", 
     RowBox[{
      OverscriptBox["v", "\[Rule]"], "\[Times]", 
      OverscriptBox["a", "\[Rule]"]}]}], "  ", "=", 
    RowBox[{
     RowBox[{
      OverscriptBox["v", "\[Rule]"], "\[Times]", "  ", 
      FractionBox[
       RowBox[{"(", " ", 
        RowBox[{"q", " ", 
         OverscriptBox["v", "\[Rule]"], " ", "\[Times]", " ", 
         OverscriptBox["B", "\[Rule]"]}], "  ", ")"}], 
       RowBox[{"\[Gamma]", " ", "m"}]]}], " ", "=", " ", 
     RowBox[{
      FractionBox["q", "\[Gamma]m"], 
      OverscriptBox["v", "\[Rule]"], "\[Times]", " ", 
      RowBox[{"(", 
       RowBox[{
        OverscriptBox["v", "\[Rule]"], " ", "\[Times]", " ", 
        OverscriptBox["B", "\[Rule]"]}], ")"}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"\[Implies]", 
     RowBox[{
      OverscriptBox["v", "\[Rule]"], "\[Times]", 
      OverscriptBox["a", "\[Rule]"]}]}], "  ", "=", " ", 
    FractionBox[
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{"e", " ", 
        SuperscriptBox["v", "2"], 
        StyleBox["B",
         FontWeight->"Bold"]}], 
       StyleBox[")",
        FontWeight->"Bold"]}]}], "\[Gamma]m"]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"\[Implies]", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        OverscriptBox["v", "\[Rule]"], "\[Times]", 
        OverscriptBox["a", "\[Rule]"]}], "  ", ")"}], "2"]}], "=", " ", 
    FractionBox[
     RowBox[{
      SuperscriptBox["e", "2"], " ", 
      SuperscriptBox["v", "4"], 
      SuperscriptBox[
       StyleBox["B",
        FontWeight->"Bold"], "2"]}], 
     RowBox[{
      SuperscriptBox["\[Gamma]", "2"], " ", 
      SuperscriptBox["m", "2"]}]]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"Hence", " ", "P"}], " ", "=", " ", 
    RowBox[{"2", " ", 
     SuperscriptBox["e", "4"], 
     SuperscriptBox["B", "2"], 
     FractionBox[
      SuperscriptBox["v", "2"], 
      RowBox[{"3", 
       SuperscriptBox["m", "2"]}]], 
     SuperscriptBox["\[Gamma]", "2"]}]}], TraditionalForm]}],
  FormatType->TraditionalForm,ExpressionUUID->
