     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["e", "i\[Omega]T"], "-", "1"}], ")"}], "i\[Omega]"]}]}],
   TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"\[Implies]", 
    RowBox[{"|", 
     RowBox[{"a", "(", "\[Omega]", ")"}], 
     SuperscriptBox["|", "2"]}]}], "=", " ", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox["eE", "m"], " ", ")"}], "2"], 
    FractionBox["1", 
     SuperscriptBox["\[Omega]", "2"]], 
    RowBox[{"(", 
