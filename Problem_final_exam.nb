     FractionBox["\[Omega]T", "2"], ")"}]}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox["Hence", TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"W", " ", "=", " ", 
   RowBox[{
    RowBox[{
     FractionBox["2", "3"], 
     SuperscriptBox["e", "2"], 
