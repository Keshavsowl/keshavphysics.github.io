Cell[TextData[{
 "A charge e of mass m is going through electric field ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["E", "o"], ",", "0", ",", "0"}], ")"}], " "}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "25567b44-c919-5647-8d96-8ce971c1f9ee"],
 " with velocity ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["v", "0"], ",", "0", ",", "0"}], ")"}], " ", "for", " ", 
    "a", " ", "distcane", " ", 
    SubscriptBox["x", "0"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "07fd0973-6f75-4c4f-819c-9865934484bd"],
 "\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
   "Accelrationn", " ", "experienced", " ", "by", " ", "the", " ", "charged", 
    " ", "particle", " ", "is"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"a", "(", "t", ")"}], " ", "=", " ", 
    RowBox[{
     RowBox[{
      FractionBox[
       SubscriptBox["eE", "0"], "m"], " ", "for", " ", "0"}], " ", "<", " ", 
     "t", " ", "<", " ", 
     SubscriptBox["t", "f"]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "let", " ", "us", " ", "find", " ", "the", " ", "fourier", " ", 
    "transform", " ", "of", " ", "the", " ", "accelaration"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["a", "~"], "(", "\[Omega]", ")"}], " ", "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"2", "\[Pi]"}]], " ", 
     RowBox[{
      SubsuperscriptBox["\[Integral]", "0", 
       SubscriptBox["t", "f"]], 
      RowBox[{
       RowBox[{"a", "(", "t", ")"}], " ", 
       SuperscriptBox["e", "i\[Omega]t"], 
       RowBox[{"\[DifferentialD]", "\[Omega]"}]}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["a", "~"], "(", "\[Omega]", ")"}], "  ", "=", " ", 
    RowBox[{
     FractionBox[
      SubscriptBox["eE", "0"], 
      RowBox[{"2", "\[Pi]", " ", "i", " ", "m\[Omega]"}]], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["e", 
        SubscriptBox["i\[Omega]t", "f"]], "-", "1"}], ")"}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["a", "~"], "(", "\[Omega]", ")"}], "  ", "=", " ", 
    RowBox[{
     FractionBox[
      RowBox[{"(", 
       RowBox[{"e", " ", 
        SubscriptBox["E", "0"]}], ")"}], "\[Pi]m\[Omega]"], " ", 
     RowBox[{"sin", "(", 
      FractionBox[
       SubscriptBox["\[Omega]t", "f"], "2"], ")"}], 
     SuperscriptBox["e", 
      FractionBox[
       SubscriptBox["i\[Omega]t", "f"], "2"]]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "let", " ", "us", " ", "now", " ", "find", " ", "out", " ", "the", " ", 
    "time", " ", "using", " ", "the", " ", "kinematic", " ", "equation", " ", 
    "of", " ", "motion"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"x", "=", " ", 
    RowBox[{"ut", " ", "-", " ", 
     RowBox[{
      FractionBox["1", "2"], "a", " ", 
      SuperscriptBox["t", "2"]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["mx", "o"], 
     SubscriptBox["eE", "o"]], " ", "=", " ", 
    RowBox[{
     RowBox[{
      FractionBox[
       SubscriptBox["mv", "o"], 
       SubscriptBox["eE", "o"]], 
      SubscriptBox["t", "f"]}], " ", "-", " ", 
     RowBox[{
      FractionBox["1", "2"], 
      FractionBox[
       SubscriptBox["eE", "0"], "m"], 
      SuperscriptBox[
       RowBox[{"(", 
        SubscriptBox["t", "f"], ")"}], "2"]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      FractionBox[
       SubscriptBox["mx", "o"], 
       SubscriptBox["eE", "o"]], " ", "+", " ", 
      FractionBox[
       SuperscriptBox[
        RowBox[{
         SuperscriptBox["m", "2"], "(", 
         SubscriptBox["v", "o"], ")"}], "2"], 
       RowBox[{"4", 
        SuperscriptBox[
         RowBox[{
          SuperscriptBox["e", "2"], "(", 
          SubscriptBox["E", "o"], ")"}], "2"]}]]}], " ", "=", " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["t", "f"], "+", " ", 
        FractionBox[
         SubscriptBox["mv", "0"], 
         RowBox[{"2", 
          SubscriptBox["eE", "o"]}]]}], ")"}], "2"]}], 
    "\[IndentingNewLine]"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"hence", " ", 
     SubscriptBox["t", "f"]}], " ", "=", " ", 
    RowBox[{
     SqrtBox[
      RowBox[{
       FractionBox["m", 
        SubscriptBox["eE", "o"]], 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["x", "o"], "+", 
         FractionBox[
          SubscriptBox["mv", "o"], 
          RowBox[{"4", 
           SubscriptBox["eE", "o"]}]]}], ")"}]}]], " ", "-", " ", 
     FractionBox[
      SubscriptBox["mv", "o"], 
      RowBox[{"2", 
       SubscriptBox["eE", "o"]}]]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox["dE", "d\[CapitalOmega]d\[Omega]"], " ", "=", " ", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"4", "\[Pi]"}], ")"}], "2"]], " ", 
     FractionBox[
      SuperscriptBox["e", "2"], 
      SuperscriptBox["\[Pi]c", "3"]], 
     SuperscriptBox[
      RowBox[{"(", " ", 
       RowBox[{"a", "(", "\[Omega]", ")"}], ")"}], "2"], 
     RowBox[{
      SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox["dE", "d\[Omega]"], " ", "=", " ", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"4", "\[Pi]"}], ")"}], "2"]], " ", 
     FractionBox[
      SuperscriptBox["e", "2"], 
      SuperscriptBox["\[Pi]c", "3"]], 
     SuperscriptBox[
      RowBox[{"(", " ", 
       RowBox[{"a", "(", "\[Omega]", ")"}], ")"}], "2"], 
     RowBox[{"\[Integral]", 
      RowBox[{"d\[CapitalOmega]", 
       RowBox[{
        SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]}]}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"Putting", " ", "the", " ", "value", " ", "of", " ", 
    RowBox[{"a", "(", "\[Omega]", ")"}], " ", "and", " ", "calcuting", " ", 
    "the", " ", "integral", " ", "again", " ", "like", " ", "in", " ", 
    "previous", " ", "question", " ", "we", " ", "will", " ", "get"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox["dE", "d\[Omega]"], " ", "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", " ", 
       FractionBox[
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["e", "2"], 
          SubscriptBox["E", "o"]}], ")"}], 
        RowBox[{"4", 
         SuperscriptBox["\[Pi]", "2"], "m", " ", "c"}]], ")"}], "2"], " ", 
     FractionBox["2", 
      SuperscriptBox["c\[Omega]", "2"]], " ", 
     RowBox[{
      SuperscriptBox["sin", "2"], "(", 
      FractionBox[
       SubscriptBox["\[Omega]t", "f"], "2"], ")"}], " ", 
     FractionBox["4", "3"]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["dE", "d\[Omega]"], " ", "=", " ", 
     RowBox[{
      FractionBox[
       SuperscriptBox[
        RowBox[{
         SuperscriptBox["e", "4"], "(", 
         RowBox[{
          SubscriptBox["t", "f"], 
          SubscriptBox["E", "o"]}], ")"}], "2"], 
       RowBox[{"6", " ", 
        SuperscriptBox["\[Pi]", "4"], "m", " ", 
        SuperscriptBox["c", "3"]}]], "  ", 
      FractionBox[
       RowBox[{
        SuperscriptBox["sin", "2"], "(", 
        FractionBox[
         SubscriptBox["\[Omega]t", "f"], "2"], ")"}], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["t", "f"], "\[Omega]"}], ")"}], "2"]], " ", 
      FractionBox["4", "3"]}]}], "\[IndentingNewLine]"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
    "Plot", " ", "will", " ", "be", " ", "almost", " ", "same", " ", "like", " ",
      "above"}], " "}], TraditionalForm], "\[IndentingNewLine]"
  FormBox[, TraditionalForm]}],
  FormatType->TraditionalForm,ExpressionUUID->
  "25aa5e67-5759-a44f-9409-f8ea714872fd"]
