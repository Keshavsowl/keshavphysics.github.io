Cell[TextData[{
 "We want to calculate and sketch the frequency distribution for a particle \
which uniformly decelerates over some time interval \[Tau]\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"accelration", " ", "a"}], " ", "=", " ", 
     RowBox[{"{", GridBox[{
        {
         RowBox[{
          FractionBox[
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["v", "f"], "-", 
             SubscriptBox["v", "i"]}], ")"}], "\[Tau]"], "  ", ",", "    ", 
          RowBox[{
           FractionBox[
            RowBox[{"-", "\[Tau]"}], "2"], "\[LessEqual]", " ", "t", "\[LessEqual]",
            " ", 
           FractionBox["\[Tau]", "2"]}]}]},
        {
         RowBox[{"0", ",", "           ", "otherwise"}]}
       }], "    ", "}"}]}], "\[IndentingNewLine]"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Let", " ", "us", " ", "fourier", " ", "transform", " ", "of", " ", "the", 
    " ", "accelaration"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["a", "\[Rule]"], "(", "\[Omega]", ")"}], " ", "=", " ", 
    RowBox[{
     RowBox[{
      FractionBox[
       OverscriptBox["z", "^"], 
       RowBox[{"2", "\[Pi]"}]], 
      RowBox[{
       SubsuperscriptBox["\[Integral]", 
        FractionBox[
         RowBox[{"-", "\[Tau]"}], "2"], 
        FractionBox["\[Tau]", "2"]], 
       RowBox[{
        FractionBox[
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["v", "f"], "-", 
           SubscriptBox["v", "i"]}], ")"}], "\[Tau]"], 
        SuperscriptBox["e", "i\[Omega]t"], 
        RowBox[{"\[DifferentialD]", "t"}]}]}]}], "    ", "=", " ", 
     RowBox[{
      RowBox[{
       FractionBox["1", "i\[Omega]"], 
       FractionBox[
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["v", "f"], "-", 
          SubscriptBox["v", "i"]}], ")"}], 
        RowBox[{"2", "\[Pi]", " ", "\[Tau]"}]], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["e", 
          FractionBox["i\[Omega]\[Tau]", "2"]], "-", " ", 
         SuperscriptBox["e", 
          RowBox[{"-", 
           FractionBox["i\[Omega]\[Tau]", "2"]}]]}], ")"}]}], " ", "=", " ", 
      RowBox[{
       FractionBox["1", "\[Omega]"], 
       FractionBox[
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["v", "f"], "-", 
          SubscriptBox["v", "i"]}], ")"}], 
        RowBox[{"\[Pi]", " ", "\[Tau]"}]], " ", 
       RowBox[{"sin", "(", 
        FractionBox["\[Omega]\[Tau]", "2"], ")"}]}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Energy", " ", "distribution", " ", "per", " ", "unit", " ", "solid", " ", 
    "angle", " ", "and", " ", "frequncy", " ", "is", " ", "given", " ", 
    "by"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["dE", "d\[CapitalOmega]d\[Omega]"], " ", "=", " ", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"4", "\[Pi]"}], ")"}], "2"]], " ", 
      SuperscriptBox[
       RowBox[{
        FractionBox[
         SuperscriptBox["e", "2"], 
         SuperscriptBox["\[Pi]c", "3"]], "[", 
        RowBox[{
         OverscriptBox["r", "^"], " ", "\[Times]", " ", 
         RowBox[{
          OverscriptBox["a", "\[Rule]"], "(", "\[Omega]", ")"}]}], "]"}], 
       "2"]}]}], "\[IndentingNewLine]"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["dE", "d\[CapitalOmega]d\[Omega]"], " ", "=", " ", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"4", "\[Pi]"}], ")"}], "2"]], " ", 
      FractionBox[
       SuperscriptBox["e", "2"], 
       SuperscriptBox["\[Pi]c", "3"]], 
      SuperscriptBox[
       RowBox[{"(", " ", 
        RowBox[{"a", "(", "\[Omega]", ")"}], ")"}], "2"], 
      RowBox[{
       SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]}]}], 
    "\[IndentingNewLine]"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox["dE", "d\[Omega]"], " ", "=", " ", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"4", "\[Pi]"}], ")"}], "2"]], " ", 
     FractionBox[
      SuperscriptBox["e", "2"], 
      SuperscriptBox["\[Pi]c", "3"]], 
     SuperscriptBox[
      RowBox[{"(", " ", 
       RowBox[{"a", "(", "\[Omega]", ")"}], ")"}], "2"], 
     RowBox[{"\[Integral]", 
      RowBox[{"d\[CapitalOmega]", 
       RowBox[{
        SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]}]}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "putting", " ", "this", " ", "into", " ", "the", " ", "mathematica", " ", 
    "we", " ", "will", " ", "get"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox["dE", "d\[Omega]"], " ", "=", "   ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["e", "2"], 
      RowBox[{"6", 
       SuperscriptBox["\[Pi]", "4"], 
       SuperscriptBox["c", "3"]}]], 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox[
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["v", "f"], "-", 
          SubscriptBox["v", "i"]}], ")"}], "\[Tau]"], ")"}], "2"], 
     FractionBox[
      RowBox[{
       SuperscriptBox["sin", "2"], "(", 
       FractionBox["\[Omega]\[Tau]", "2"], ")"}], 
      SuperscriptBox["\[Omega]", "2"]]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox["dE", "d\[Omega]"], " ", "=", "   ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["e", "2"], 
      RowBox[{"24", 
       SuperscriptBox["\[Pi]", "4"], 
       SuperscriptBox["c", "3"]}]], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["v", "f"], "-", 
         SubscriptBox["v", "i"]}], ")"}], ")"}], "2"], 
     FractionBox[
      RowBox[{
       SuperscriptBox["sin", "2"], "(", 
       FractionBox["\[Omega]\[Tau]", "2"], ")"}], 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["\[Omega]\[Tau]", "2"], ")"}], "2"]]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"variation", " ", "of", " ", 
    FractionBox["dE", "d\[Omega]"], " ", "will", " ", "be", " ", "like"}], 
   TraditionalForm]}],
  FormatType->TraditionalForm,ExpressionUUID->
  "db48c910-311b-d845-9c2c-78ba40331430"]
}], "Text",
 CellChangeTimes->{{3.974071959568527*^9, 3.9740725296611595`*^9}, {
  3.9740725983787766`*^9, 3.9740726296099033`*^9}, {3.974072687316183*^9, 
  3.9740727125245686`*^9}, {3.9740727428502026`*^9, 3.9740728498561497`*^9}, {
  3.974072885853754*^9, 3.9740729139859543`*^9}, {3.9740729454797974`*^9, 
  3.9740730436249256`*^9}, {3.9740730966130505`*^9, 3.974073213567932*^9}, {
  3.974073257119047*^9, 3.9740733183292217`*^9}, {3.9740733562079334`*^9, 
  3.974073390703989*^9}, {3.974075691174446*^9, 3.9740756942992153`*^9}, {
  3.9740757519279213`*^9, 
  3.974075759724983*^9}},ExpressionUUID->"a3fd3971-01b2-3f4d-9b9c-\
9d67cfd17994"],

