     SqrtBox[
      RowBox[{"2", 
       FractionBox["k", "m"]}]], "   ", "=", 
     RowBox[{"5.931", "\[Times]", 
      SuperscriptBox["10", "8"], 
      RowBox[{"m", "/", "s"}]}]}]}], "\[IndentingNewLine]"}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[Theta]", "c"], "(", "e", ")"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"70.2", " ", "degree", "        ", 
