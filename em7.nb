Cell[TextData[{
 "Given\nv(t) = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["v", "\[Rule]"], "o"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6cfb5e37-0471-1b46-b6d4-b066361bf099"],
 " = constant\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    OverscriptBox[
     RowBox[{"v", "(", "t", ")"}], 
     RowBox[{" ", "."}]], " ", "=", " ", "0"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["v", "\[Rule]"], "(", "\[Omega]", ")"}], " ", "=", " ", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"2", "\[Pi]"}]], 
      RowBox[{
       SubsuperscriptBox["\[Integral]", 
        RowBox[{"-", "\[Infinity]"}], "\[Infinity]"], 
       RowBox[{
        SubscriptBox[
         OverscriptBox["v", "\[Rule]"], "o"], " ", 
        SuperscriptBox["e", "i\[Omega]t"], 
        RowBox[{"\[DifferentialD]", "t"}]}]}]}], "  ", "=", 
     RowBox[{
      SubscriptBox[
       OverscriptBox["v", "\[Rule]"], "o"], " ", 
      RowBox[{"\[Delta]", "(", "\[Omega]", ")"}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["a", "\[Rule]"], "(", "\[Omega]", ")"}], "  ", "=", " ", 
    "0"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Plugging", " ", "into", " ", "the", " ", "expression", " ", "that", " ", 
    "are", " ", "given", " ", "in", " ", "the", " ", "questions"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox["dE", "d\[CapitalOmega]d\[Omega]"], " ", "=", " ", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"4", "\[Pi]"}], ")"}], "2"]], " ", 
      SuperscriptBox[
       RowBox[{
        FractionBox[
         RowBox[{
          SuperscriptBox["e", "2"], " ", 
          SuperscriptBox["\[Omega]", "2"]}], 
         SuperscriptBox["\[Pi]c", "3"]], "[", 
        RowBox[{
         OverscriptBox["r", "^"], " ", "\[Times]", " ", 
         RowBox[{
          OverscriptBox["v", "\[Rule]"], "(", "\[Omega]", ")"}]}], "]"}], 
       "2"]}], "  ", "=", " ", 
     RowBox[{
      RowBox[{
       FractionBox["1", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"4", "\[Pi]"}], ")"}], "2"]], " ", 
       SuperscriptBox[
        RowBox[{
         FractionBox[
          RowBox[{
           SuperscriptBox["e", "2"], " ", 
           SuperscriptBox["\[Omega]", "2"]}], 
          SuperscriptBox["\[Pi]c", "3"]], "[", 
         RowBox[{
          OverscriptBox["r", "^"], " ", "\[Times]", 
          SubscriptBox[
           OverscriptBox["v", "\[Rule]"], "o"], " ", 
          RowBox[{"\[Delta]", "(", "\[Omega]", ")"}]}], "]"}], "2"]}], "  ", "=",
       " ", 
      RowBox[{
       FractionBox["1", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"4", "\[Pi]"}], ")"}], "2"]], " ", 
       FractionBox[
        RowBox[{
         SuperscriptBox["e", "2"], " ", 
         SuperscriptBox["\[Omega]", "2"]}], 
        SuperscriptBox["\[Pi]c", "3"]], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         SubscriptBox["v", "o"], " ", ")"}], "2"], 
       RowBox[{
        SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}], 
       RowBox[{
        SuperscriptBox["\[Delta]", "2"], "(", "\[Omega]", ")"}]}]}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox["dE", "d\[CapitalOmega]d\[Omega]"], " ", "=", " ", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"4", "\[Pi]"}], ")"}], "2"]], " ", 
      SuperscriptBox[
       RowBox[{
        FractionBox[
         RowBox[{
          SuperscriptBox["e", "2"], " "}], 
         SuperscriptBox["\[Pi]c", "3"]], "[", 
        RowBox[{
         OverscriptBox["r", "^"], " ", "\[Times]", 
         RowBox[{
          OverscriptBox["a", "\[Rule]"], "(", "\[Omega]", ")"}]}], "]"}], 
       "2"]}], "  ", "=", " ", "0"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{" "}], TraditionalForm]}],
  FormatType->TraditionalForm,ExpressionUUID->
  "d2371e88-84a4-3e40-83db-4c51b6f4ac3b"]
}], "Text",
