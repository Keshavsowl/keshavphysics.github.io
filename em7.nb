     SuperscriptBox["10", 
      RowBox[{"-", "10"}]], " ", "J"}]}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"m", "(", "p", ")"}], " ", "=", " ", 
   RowBox[{"1.6", " ", "\[Times]", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "27"}]], "kg"}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"m", "(", "e", ")"}], " ", "=", " ", 
