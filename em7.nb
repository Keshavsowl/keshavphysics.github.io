Cell[TextData[{
 StyleBox["a",
  FontWeight->"Bold"],
 "\nEnergy radiated into the solid angle d\[CapitalOmega] per unit retarded \
time is given by\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
   "Equation", " ", "15.25", " ", "for", " ", "the", " ", "1", " ", 
    "particle", " ", "is", " ", "written", " ", "by"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"dP", "(", 
      RowBox[{"t", "'"}], ")"}], "d\[CapitalOmega]"], " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox[
        SuperscriptBox[
         RowBox[{
          FractionBox[
           SuperscriptBox["e", "2"], 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"4", "\[Pi]"}], ")"}], "2"], 
            SuperscriptBox["c", "3"]}]], "  ", "[", 
          RowBox[{
           OverscriptBox["r", "^"], "\[Times]", 
           RowBox[{"(", 
            RowBox[{
             OverscriptBox["a", "\[Rule]"], " ", "+", " ", 
             RowBox[{
              OverscriptBox["r", "^"], " ", "\[Times]", " ", 
              RowBox[{"(", 
               RowBox[{
                FractionBox[
                 OverscriptBox["v", "\[Rule]"], "c"], "\[Times]", " ", 
                OverscriptBox["a", "\[Rule]"]}], ")"}]}]}], ")"}]}], "]"}], 
         "2"], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            FractionBox[
             OverscriptBox["v", "\[Rule]"], "c"], ".", 
            OverscriptBox["r", "^"]}]}], ")"}], "5"]], " ", "--"}], "--"}], 
     RowBox[{"(", "B", ")"}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"z", "(", 
      RowBox[{"t", "'"}], ")"}], " ", "=", " ", 
     RowBox[{"a", " ", 
      RowBox[{"cos", "(", 
       RowBox[{
        SubscriptBox["\[Omega]", "o"], 
        RowBox[{"t", "'"}]}], ")"}]}]}], " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["z", "."], "(", 
     RowBox[{"t", "'"}], ")"}], " ", "=", " ", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "z"], "(", 
      RowBox[{"t", "'"}], ")"}], " ", "=", " ", 
     RowBox[{
      RowBox[{"-", 
       SubscriptBox["a\[Omega]", "o"]}], " ", 
      RowBox[{"sin", "(", 
       RowBox[{
        SubscriptBox["\[Omega]", "o"], 
        RowBox[{"t", "'"}]}], ")"}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["z", ".."], "(", 
     RowBox[{"t", "'"}], ")"}], " ", "=", " ", 
    RowBox[{
     RowBox[{
      SubscriptBox["a", "z"], "(", 
      RowBox[{"t", "'"}], ")"}], " ", "=", " ", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox[
        RowBox[{"a", "(", 
         SubscriptBox["\[Omega]", "o"], ")"}], "2"]}], " ", 
      RowBox[{"cos", "(", 
       RowBox[{
        SubscriptBox["\[Omega]", "o"], 
        RowBox[{"t", "'"}]}], ")"}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["z", "."], "(", 
      RowBox[{"t", "'"}], ")"}], "  ", "\[Times]", " ", 
     RowBox[{
      OverscriptBox["z", ".."], "(", 
      RowBox[{"t", "'"}], ")"}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{
      OverscriptBox["v", "\[Rule]"], " ", "\[Times]", " ", 
      OverscriptBox["a", "\[Rule]"]}], "  ", "=", " ", "0"}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Hence", " ", "the", " ", "equation", " ", "B", " ", "can", " ", "be", " ",
     "writtten", " ", "as", " ", "a"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"dP", "(", 
      RowBox[{"t", "'"}], ")"}], "d\[CapitalOmega]"], " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           FractionBox[
            SuperscriptBox[
             RowBox[{
              SuperscriptBox["e", "2"], "  ", "[", 
              RowBox[{
               OverscriptBox["r", "^"], "\[Times]", 
               OverscriptBox["a", "\[Rule]"]}], " ", "]"}], "2"], 
            RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"4", "\[Pi]"}], ")"}], "2"], 
             SuperscriptBox[
              RowBox[{
               SuperscriptBox["c", "3"], "(", 
               RowBox[{"1", "-", 
                RowBox[{
                 FractionBox[
                  OverscriptBox["v", "\[Rule]"], "c"], ".", 
                 OverscriptBox["r", "^"]}]}], ")"}], "5"]}]], "   ", "--"}], 
          "--"}], "--"}], "--"}], "--"}], "--"}], "-", "C"}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"let", " ", "us", " ", "calculate", " ", "the", " ", 
    OverscriptBox["r", "^"], "\[Times]", 
    OverscriptBox["a", "\[Rule]"], " ", "and", " ", 
    RowBox[{
     OverscriptBox["v", "\[Rule]"], ".", 
     OverscriptBox["r", "^"]}], " ", "for", " ", "our", " ", "case"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["r", "^"], "\[Times]", 
     OverscriptBox["a", "\[Rule]"]}], "  ", "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"a", "(", 
       SubscriptBox["\[Omega]", "o"], ")"}], "2"], 
     RowBox[{"cos", "(", 
      RowBox[{
       SubscriptBox["\[Omega]", "o"], 
       RowBox[{"t", "'"}]}], ")"}], " ", 
     RowBox[{"(", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"sin", "(", "\[Theta]", ")"}], " ", 
        RowBox[{"cos", "(", "\[Phi]", " ", ")"}], " ", 
        OverscriptBox["x", "^"]}], " ", "+", " ", 
       RowBox[{
        RowBox[{"sin", "(", "\[Theta]", ")"}], " ", 
        RowBox[{"sin", "(", "\[Phi]", ")"}], " ", 
        OverscriptBox["y", "^"]}], " ", "+", " ", 
       RowBox[{
        RowBox[{"cos", "(", "\[Theta]", ")"}], " ", 
        OverscriptBox["z", "^"]}]}], ")"}], 
     StyleBox["\[Times]",
      FontWeight->"Bold"], "  ", 
     OverscriptBox["z", "^"]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"  ", 
    RowBox[{
     RowBox[{
      OverscriptBox["r", "^"], "\[Times]", 
      OverscriptBox["a", "\[Rule]"]}], "  ", "=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"a", "(", 
        SubscriptBox["\[Omega]", "o"], ")"}], "2"], 
      RowBox[{"cos", "(", 
       RowBox[{
        SubscriptBox["\[Omega]", "o"], 
        RowBox[{"t", "'"}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          RowBox[{"sin", "(", "\[Theta]", ")"}]}], " ", 
         RowBox[{"cos", "(", "\[Phi]", " ", ")"}], " ", 
         OverscriptBox["y", "^"]}], " ", "+", " ", 
        RowBox[{
         RowBox[{"sin", "(", "\[Theta]", ")"}], " ", 
         RowBox[{"sin", "(", "\[Phi]", ")"}], " ", 
         OverscriptBox["x", "^"]}]}], " ", ")"}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", "  ", 
       RowBox[{
        OverscriptBox["r", "^"], "\[Times]", 
        OverscriptBox["a", "\[Rule]"]}], "  ", ")"}], "2"], " ", "=", " ", 
     RowBox[{
      SuperscriptBox[
       RowBox[{
        SuperscriptBox["a", "2"], "(", 
        SubscriptBox["\[Omega]", "o"], ")"}], "4"], 
      RowBox[{
       SuperscriptBox["cos", "2"], "(", 
       RowBox[{
        SubscriptBox["\[Omega]", "o"], 
        RowBox[{"t", "'"}]}], ")"}], "  ", 
      RowBox[{
       SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]}]}], " "}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"  ", 
    RowBox[{
     RowBox[{"1", "-", 
      RowBox[{
       FractionBox[
        OverscriptBox["v", "\[Rule]"], "c"], ".", 
       OverscriptBox["r", "^"]}]}], "  ", "=", " ", 
     RowBox[{"1", "  ", "+", " ", 
      RowBox[{
       FractionBox["1", "c"], " ", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["a\[Omega]", "o"], " ", 
         RowBox[{"sin", "(", 
          RowBox[{
           SubscriptBox["\[Omega]", "o"], 
           RowBox[{"t", "'"}]}], ")"}], 
         RowBox[{
          OverscriptBox["z", "^"], "  ", ".", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"sin", "(", "\[Theta]", ")"}], " ", 
             RowBox[{"cos", "(", "\[Phi]", " ", ")"}], " ", 
             OverscriptBox["x", "^"]}], " ", "+", " ", 
            RowBox[{
             RowBox[{"sin", "(", "\[Theta]", ")"}], " ", 
             RowBox[{"sin", "(", "\[Phi]", ")"}], " ", 
             OverscriptBox["y", "^"]}], " ", "+", " ", 
            RowBox[{
             RowBox[{"cos", "(", "\[Theta]", ")"}], " ", 
             OverscriptBox["z", "^"]}]}], ")"}]}]}], ")"}]}]}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"1", "-", 
     RowBox[{
      FractionBox[
       OverscriptBox["v", "\[Rule]"], "c"], ".", 
      OverscriptBox["r", "^"]}]}], "   ", "=", " ", 
    RowBox[{
     RowBox[{"1", " ", "+", " ", 
      RowBox[{
       FractionBox["1", "c"], 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["a\[Omega]", "o"], " ", 
         RowBox[{"cos", "(", "\[Theta]", ")"}], " ", 
         RowBox[{"sin", "(", 
          RowBox[{
           SubscriptBox["\[Omega]", "o"], 
           RowBox[{"t", "'"}]}], ")"}]}], ")"}]}]}], " ", "=", " ", 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{"\[Beta]", " ", 
       RowBox[{"cos", "(", "\[Theta]", ")"}], " ", 
       RowBox[{"sin", "(", 
        RowBox[{
         SubscriptBox["\[Omega]", "o"], 
         RowBox[{"t", "'"}]}], ")"}]}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Putting", " ", "everyting", " ", "on", " ", "the", " ", "equation", " ", 
    "C"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"dP", "(", 
       RowBox[{"t", "'"}], ")"}], "d\[CapitalOmega]"], " ", "=", " ", 
     RowBox[{
      FractionBox[
       SuperscriptBox[
        RowBox[{
         SuperscriptBox["e", "2"], "  ", "[", 
         RowBox[{
          OverscriptBox["r", "^"], "\[Times]", 
          OverscriptBox["a", "\[Rule]"]}], " ", "]"}], "2"], 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"4", "\[Pi]"}], ")"}], "2"], 
        SuperscriptBox[
         RowBox[{
          SuperscriptBox["c", "3"], "(", 
          RowBox[{"1", "-", 
           RowBox[{
            FractionBox[
             OverscriptBox["v", "\[Rule]"], "c"], ".", 
            OverscriptBox["r", "^"]}]}], ")"}], "5"]}]], "    ", "=", " ", 
      FractionBox[
       RowBox[{
        SuperscriptBox["e", "2"], "(", " ", 
        RowBox[{
         SuperscriptBox["a", "2"], 
         SuperscriptBox[
          RowBox[{"(", 
           SubscriptBox["\[Omega]", "o"], ")"}], "4"], 
         RowBox[{
          SuperscriptBox["cos", "2"], "(", 
          RowBox[{
           SubscriptBox["\[Omega]", "o"], 
           RowBox[{"t", "'"}]}], ")"}], "  ", 
         RowBox[{
          SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]}], " ", ")"}], 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"4", "\[Pi]"}], ")"}], "2"], 
        SuperscriptBox[
         RowBox[{
          SuperscriptBox["c", "3"], "(", 
          RowBox[{"1", " ", "+", " ", 
           RowBox[{"\[Beta]", " ", 
            RowBox[{"cos", "(", "\[Theta]", ")"}], " ", 
            RowBox[{"sin", "(", 
             RowBox[{
              SubscriptBox["\[Omega]", "o"], 
              RowBox[{"t", "'"}]}], ")"}]}]}], ")"}], "5"]}]]}]}], " "}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "which", " ", "can", " ", "be", " ", "further", " ", "written", " ", "as", 
    " ", "a"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"dP", "(", 
       RowBox[{"t", "'"}], ")"}], "d\[CapitalOmega]"], " ", "=", "  ", 
     FractionBox[
      RowBox[{
       RowBox[{
        SuperscriptBox["e", "2"], "c", " ", 
        SuperscriptBox["\[Beta]", "4"], 
        RowBox[{
         SuperscriptBox["cos", "2"], "(", 
         RowBox[{
          SubscriptBox["\[Omega]", "o"], 
          RowBox[{"t", "'"}]}], ")"}], "  ", 
        RowBox[{
         SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]}], " ", ")"}], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"4", "\[Pi]"}], ")"}], "2"], 
       SuperscriptBox[
        RowBox[{
         SuperscriptBox["a", "2"], "(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"\[Beta]", " ", 
           RowBox[{"cos", "(", "\[Theta]", ")"}], " ", 
           RowBox[{"sin", "(", 
            RowBox[{
             SubscriptBox["\[Omega]", "o"], 
             RowBox[{"t", "'"}]}], ")"}]}]}], ")"}], "5"]}]]}], " "}], 
   TraditionalForm], "\[IndentingNewLine]"
  FormBox[, TraditionalForm]}],
  InitializationCell->True,ExpressionUUID->
  "071281c6-4c33-814e-a1ff-516c97be0c96"],
