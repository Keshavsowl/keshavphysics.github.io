     OverscriptBox["A", "."]}]}], "         ", ",", " ", 
   RowBox[{
    SubscriptBox["\[Omega]", "1"], "   ", "=", 
    RowBox[{
     FractionBox[
      RowBox[{"(", " ", 
       RowBox[{"2", "\[Pi]", " ", "c"}], ")"}], 
      SubscriptBox["\[Lambda]", "1"]], " ", "=", "  ", 
     RowBox[{"4.712", "\[Times]", " ", 
      SuperscriptBox["10", "15"]}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "2"], " ", "=", " ", 
     RowBox[{"6000", " ", 
      OverscriptBox["A", "."]}]}], "         ", ",", " ", 
    RowBox[{
     SubscriptBox["\[Omega]", "1"], "   ", "=", 
     RowBox[{
      FractionBox[
       RowBox[{"(", " ", 
        RowBox[{"2", "\[Pi]", " ", "c"}], ")"}], 
       SubscriptBox["\[Lambda]", "1"]], " ", "=", "  ", 
      RowBox[{"3.142", "\[Times]", " ", 
       SuperscriptBox["10", "15"]}]}]}]}], "\[IndentingNewLine]"}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"refractive", " ", "index"}], " ", "=", " ", "1.5"}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"KE", " ", 
    RowBox[{"(", "Proton", ")"}]}], " ", "=", " ", 
   RowBox[{
    RowBox[{
     SuperscriptBox["10", "6"], " ", "eV"}], " ", "=", " ", 
    RowBox[{"1.602", " ", "\[Times]", " ", 
     SuperscriptBox["10", 
      RowBox[{"-", "13"}]], "J"}]}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"KE", " ", 
    RowBox[{"(", "Proton", ")"}]}], " ", "=", " ", 
