Cell[TextData[{
 "We have to show that relativistic result for the instantaneous energy \
radiated per unit time by the particle of charge ze in ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["E", "\[Rule]"], TraditionalForm]],ExpressionUUID->
  "60cd65dc-54be-2f4f-b530-bfecc04e71aa"],
 " and ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["B", "\[Rule]"], TraditionalForm]],ExpressionUUID->
  "1c882050-15d5-6746-a76f-0d9ada6ba66b"],
 " is given by\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{"P", " ", "=", " ", 
    RowBox[{
     FractionBox["2", "3"], " ", 
     RowBox[{
      FractionBox[
       SuperscriptBox[
        RowBox[{"(", "ze", ")"}], "2"], 
       RowBox[{"4", "\[Pi]", " ", 
        SuperscriptBox["m", "2"], " ", 
        SuperscriptBox["c", "3"]}]], "[", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          OverscriptBox["E", "\[Rule]"], " ", "+", 
          RowBox[{
           FractionBox[
            RowBox[{
             OverscriptBox["v", "\[Rule]"], " "}], "c"], "\[Times]", " ", 
           OverscriptBox["B", "\[Rule]"]}]}], ")"}], "2"], "-", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          FractionBox[
           OverscriptBox["v", "\[Rule]"], "c"], ".", 
          OverscriptBox["E", "\[Rule]"]}], ")"}], "2"]}], "  ", "]"}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
    "We", " ", "have", " ", "found", " ", "from", " ", "the", " ", "previous",
      " ", "result", " ", "that", " ", "power", " ", "emitted", " ", "by", " ",
      "the", " ", "charge", " ", "partice", " ", "in", " ", "the", " ", 
     "force", " ", "field", " ", "is"}], " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"P", " ", "=", " ", 
    RowBox[{
     FractionBox["2", "3"], " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           FractionBox[
            SuperscriptBox[
             RowBox[{"(", "ze", ")"}], "2"], 
            RowBox[{"4", "\[Pi]", " ", 
             SuperscriptBox["m", "2"], " ", 
             SuperscriptBox["c", "3"]}]], "[", 
           RowBox[{
            SuperscriptBox["F", "2"], " ", "-", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               OverscriptBox["\[Beta]", "\[Rule]"], ".", 
               OverscriptBox["F", "\[Rule]"]}], ")"}], "2"]}], "  ", "]"}], 
          "              ", "--"}], "--"}], "--"}], "--"}], "--"}], 
     RowBox[{"(", "A", ")"}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "Totale", " ", "electromagnetic", " ", "force", " ", "on", " ", "the", " ",
     "particle", "  ", "is", " ", "given", " ", "by"}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    OverscriptBox["F", "\[Rule]"], " ", "=", " ", 
    RowBox[{"ze", "(", 
     RowBox[{
      OverscriptBox["E", "\[Rule]"], " ", "+", " ", 
      FractionBox[
       RowBox[{
        OverscriptBox["v", "\[Rule]"], "\[Times]", 
        OverscriptBox["B", "\[Rule]"]}], "c"]}], ")"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"Let", " ", "us", " ", "calculate", " ", "the"}], " "}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SuperscriptBox["F", "2"], " ", "=", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"ze", "(", 
       RowBox[{
        OverscriptBox["E", "\[Rule]"], " ", "+", " ", 
        FractionBox[
         RowBox[{
          OverscriptBox["v", "\[Rule]"], "\[Times]", 
          OverscriptBox["B", "\[Rule]"]}], "c"]}], ")"}], ".", 
      RowBox[{"ze", "(", 
       RowBox[{
        OverscriptBox["E", "\[Rule]"], " ", "+", " ", 
        FractionBox[
         RowBox[{
          OverscriptBox["v", "\[Rule]"], "\[Times]", 
          OverscriptBox["B", "\[Rule]"]}], "c"]}], ")"}]}], " ", "=", " ", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", "ze", ")"}], "2"], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         OverscriptBox["E", "\[Rule]"], " ", "+", " ", 
         FractionBox[
          RowBox[{
           OverscriptBox["v", "\[Rule]"], "\[Times]", 
           OverscriptBox["B", "\[Rule]"]}], "c"]}], ")"}], "2"]}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"let", " ", "us", " ", "evaluate", "  ", "now"}], " "}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[Beta]", "\[Rule]"], ".", 
     OverscriptBox["F", "\[Rule]"]}], " ", "=", "  ", 
    RowBox[{
     RowBox[{"ze", 
      RowBox[{
       OverscriptBox["\[Beta]", "\[Rule]"], ".", " ", 
       RowBox[{"(", 
        RowBox[{
         OverscriptBox["E", "\[Rule]"], " ", "+", " ", 
         FractionBox[
          RowBox[{
           OverscriptBox["v", "\[Rule]"], "\[Times]", 
           OverscriptBox["B", "\[Rule]"]}], "c"]}], ")"}]}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{"ze", "(", 
       RowBox[{
        RowBox[{
         OverscriptBox["\[Beta]", "\[Rule]"], ".", 
         OverscriptBox["E", "\[Rule]"]}], "  ", "+", " ", 
        RowBox[{
         OverscriptBox["\[Beta]", "\[Rule]"], ".", 
         FractionBox[
          RowBox[{
           OverscriptBox["v", "\[Rule]"], "\[Times]", 
           OverscriptBox["B", "\[Rule]"]}], "c"]}]}], ")"}], " ", "=", " ", 
      RowBox[{"ze", "(", 
       RowBox[{
        OverscriptBox["\[Beta]", "\[Rule]"], ".", 
        OverscriptBox["E", "\[Rule]"]}], ")"}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[Beta]", "\[Rule]"], ".", 
     OverscriptBox["F", "\[Rule]"]}], "  ", "=", " ", 
    RowBox[{"ze", "(", 
     RowBox[{
      FractionBox[
       OverscriptBox["v", "\[Rule]"], "c"], ".", 
      OverscriptBox["E", "\[Rule]"]}], ")"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"Putting", " ", "everything", " ", "in", " ", "the", " ", 
    RowBox[{"(", "A", ")"}], " ", "we", " ", "will", " ", "get"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"P", " ", "=", " ", 
     RowBox[{
      FractionBox["2", "3"], " ", 
      RowBox[{
       FractionBox[
        SuperscriptBox[
         RowBox[{"(", "ze", ")"}], "2"], 
        RowBox[{"4", "\[Pi]", " ", 
         SuperscriptBox["m", "2"], " ", 
         SuperscriptBox["c", "3"]}]], "[", 
       RowBox[{
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", "ze", ")"}], "2"], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            OverscriptBox["E", "\[Rule]"], " ", "+", " ", 
            FractionBox[
             RowBox[{
              OverscriptBox["v", "\[Rule]"], "\[Times]", 
              OverscriptBox["B", "\[Rule]"]}], "c"]}], ")"}], "2"]}], "-", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"ze", "(", 
           RowBox[{
            FractionBox[
             OverscriptBox["v", "\[Rule]"], "c"], ".", 
            OverscriptBox["E", "\[Rule]"]}], ")"}], ")"}], "2"]}], "  ", 
       "]"}]}]}], "  "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"P", " ", "=", "  ", 
     RowBox[{
      FractionBox["2", "3"], " ", 
      RowBox[{
       FractionBox[
        SuperscriptBox[
         RowBox[{"(", "ze", ")"}], "4"], 
        RowBox[{"4", "\[Pi]", " ", 
         SuperscriptBox["m", "2"], " ", 
         SuperscriptBox["c", "3"]}]], "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           OverscriptBox["E", "\[Rule]"], " ", "+", " ", 
           FractionBox[
            RowBox[{
             OverscriptBox["v", "\[Rule]"], "\[Times]", 
             OverscriptBox["B", "\[Rule]"]}], "c"]}], ")"}], "2"], "-", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           FractionBox[
            OverscriptBox["v", "\[Rule]"], "c"], ".", 
           OverscriptBox["E", "\[Rule]"]}], ")"}], "2"]}], "  ", "]"}]}]}], " ", 
    "\[IndentingNewLine]" FormBox[Null, TraditionalForm]}], 
   TraditionalForm]}],ExpressionUUID->"164d5250-ac92-9946-81a3-34ea865bcbb2"]
}], "Text",
