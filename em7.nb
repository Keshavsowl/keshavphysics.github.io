Cell[TextData[Cell[BoxData[{
 FormBox[
  RowBox[{"Photon", " ", "density", " ", "per", " ", "unit", " ", "lenght"}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   FractionBox["dN", "dz"], " ", "=", " ", 
   RowBox[{
    RowBox[{
     FractionBox["1", 
      RowBox[{"137", "c"}]], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       SubscriptBox["\[Omega]", "2"], 
       SubscriptBox["\[Omega]", "1"]], "1"}]}], " ", "-", " ", 
    RowBox[{
     RowBox[{
      SuperscriptBox["cos", "2"], "(", 
      SubscriptBox["\[Theta]", "c"], ")"}], " ", 
     RowBox[{"\[DifferentialD]", "      ", 
      RowBox[{"--", 
       RowBox[{"--", 
        RowBox[{"--", 
         StyleBox["D",
          FontWeight->"Bold"]}]}]}]}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"where", " ", 
    RowBox[{"Cos", "(", 
     SubscriptBox["\[Theta]", "c"], ")"}]}], " ", "=", " ", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"\[Beta]", " ", "n"}]], " ", "=", " ", 
    FractionBox["c", "vn"]}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"we", " ", "have", " ", "to", " ", "find", " ", "the", " ", 
