Cell[TextData[Cell[BoxData[{
 FormBox[
  RowBox[{
   FractionBox[
    RowBox[{
     OverscriptBox["dP", "_"], "(", 
     RowBox[{"t", "'"}], ")"}], "d\[CapitalOmega]"], "=", 
   RowBox[{
    RowBox[{"\[Integral]", 
     RowBox[{
      FractionBox[
       RowBox[{"dP", "(", 
        RowBox[{"t", "'"}], ")"}], "d\[CapitalOmega]"], 
      RowBox[{"\[DifferentialD]", 
       RowBox[{"t", "'"}]}]}]}], "  ", "=", " ", 
    FractionBox[
     RowBox[{"(", 
      RowBox[{
       SubsuperscriptBox["\[Integral]", "0", 
        FractionBox[
         RowBox[{"(", 
          RowBox[{"2", "\[Pi]"}], ")"}], "\[Omega]"]], 
       RowBox[{
        FractionBox[
         RowBox[{
          SuperscriptBox["e", "2"], "c", " ", 
          SuperscriptBox["\[Beta]", "4"], 
          RowBox[{
           SuperscriptBox["cos", "2"], "(", 
           RowBox[{
            SubscriptBox["\[Omega]", "o"], 
            RowBox[{"t", "'"}]}], ")"}], "  ", 
          RowBox[{
           SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}], " "}], 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"4", "\[Pi]"}], ")"}], "2"], 
          SuperscriptBox[
           RowBox[{
            SuperscriptBox["a", "2"], "(", 
            RowBox[{"1", " ", "+", " ", 
             RowBox[{"\[Beta]", " ", 
              RowBox[{"cos", "(", "\[Theta]", ")"}], " ", 
              RowBox[{"sin", "(", 
               RowBox[{
                SubscriptBox["\[Omega]", "o"], 
                RowBox[{"t", "'"}]}], ")"}]}]}], ")"}], "5"]}]], " ", 
        RowBox[{"\[DifferentialD]", 
         RowBox[{"t", "'"}]}]}]}], ")"}], 
     FractionBox[
      RowBox[{"2", "\[Pi]"}], 
      SubscriptBox["\[Omega]", "0"]]]}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   FractionBox[
    RowBox[{
     OverscriptBox["dP", "_"], "(", 
     RowBox[{"t", "'"}], ")"}], "d\[CapitalOmega]"], " ", "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      SubscriptBox["\[Omega]", "0"], "(", " ", 
      RowBox[{
       SuperscriptBox["e", "2"], "c", " ", 
       SuperscriptBox["\[Beta]", "4"], 
       RowBox[{
        SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]}], ")"}], 
     RowBox[{"2", "\[Pi]", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"4", "\[Pi]"}], ")"}], "2"], 
      SuperscriptBox["a", "2"]}]], 
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", 
      FractionBox[
       RowBox[{"(", 
        RowBox[{"2", "\[Pi]"}], ")"}], 
       SubscriptBox["\[Omega]", "0"]]], 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{
         SuperscriptBox["cos", "2"], "(", 
         RowBox[{
          SubscriptBox["\[Omega]", "o"], 
          RowBox[{"t", "'"}]}], ")"}], "   ", ")"}], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"\[Beta]", " ", 
           RowBox[{"cos", "(", "\[Theta]", ")"}], " ", 
           RowBox[{"sin", "(", 
            RowBox[{
             SubscriptBox["\[Omega]", "o"], 
             RowBox[{"t", "'"}]}], ")"}]}]}], ")"}], "5"]], " ", 
      RowBox[{"\[DifferentialD]", 
       RowBox[{"t", "'"}]}]}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
  "Calcuating", " ", "the", " ", "inside", " ", "the", " ", "integration", " ",
    "in", " ", "the", " ", "mathematica"}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{
      OverscriptBox["dP", "_"], "(", 
      RowBox[{"t", "'"}], ")"}], "d\[CapitalOmega]"], " ", "=", " ", 
    RowBox[{
     FractionBox[
      RowBox[{" ", 
       RowBox[{
        SuperscriptBox["e", "2"], "c", " ", 
        SuperscriptBox["\[Beta]", "4"], 
        RowBox[{
         SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]}]}], 
      RowBox[{
       SuperscriptBox[
        RowBox[{
         RowBox[{"128", "\[Pi]"}], ")"}], "2"], 
       SuperscriptBox["a", "2"]}]], " ", 
     FractionBox[
      RowBox[{"(", 
       RowBox[{"4", "+", 
        RowBox[{
         SuperscriptBox["\[Beta]", "2"], " ", 
         RowBox[{
          SuperscriptBox["cos", "2"], "(", "\[Theta]", ")"}]}]}], ")"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{
          SuperscriptBox["\[Beta]", "2"], 
          RowBox[{
           SuperscriptBox["cos", "2"], "(", "\[Theta]", ")"}]}]}], ")"}], 
       FractionBox["7", "2"]]]}]}], "\[IndentingNewLine]"}], 
  TraditionalForm], "\[IndentingNewLine]"
 FormBox[, 
  TraditionalForm]}],ExpressionUUID->"aa6f93c0-b245-064b-ba97-713083fc8cb6"]],\
 "Text",
 CellChangeTimes->{{3.973982152823721*^9, 3.973982321856205*^9}, {
  3.974071011606615*^9, 3.9740710577998486`*^9}, {3.974071112305958*^9, 
