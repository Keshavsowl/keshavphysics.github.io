     SuperscriptBox["10", 
      RowBox[{"-", "31"}]], "kg"}]}], "  "}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"v", "(", "e", ")"}], "   ", "=", " ", 
   RowBox[{
    SqrtBox[
     RowBox[{"2", 
      FractionBox["k", "m"]}]], "   ", "=", 
    RowBox[{"4.736", "\[Times]", 
     SuperscriptBox["10", "8"], 
     RowBox[{"m", "/", "s"}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"v", "(", "p", ")"}], "   ", "=", " ", 
