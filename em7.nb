       RowBox[{"4", "\[Pi]", " ", 
        SuperscriptBox["m", "2"], " ", 
        SuperscriptBox["c", "3"]}]], "[", 
      RowBox[{
       SuperscriptBox["F", "2"], " ", "-", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          OverscriptBox["\[Beta]", "\[Rule]"], ".", 
          OverscriptBox["F", "\[Rule]"]}], ")"}], "2"]}], " ", " ", "]"}]}]}],
    TraditionalForm]}],ExpressionUUID->"83bad91c-88c3-3343-8dbe-55b4e4b7109b"]
}], "Text",
