Cell[TextData[{
 "In the rest frame magnetic field is given by\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    OverscriptBox["B", "\[Rule]"], "  ", "=", " ", 
    RowBox[{"{", GridBox[{
       {
        RowBox[{
         RowBox[{"B", "=", " ", 
          RowBox[{
           SubscriptBox["B", "o"], 
           OverscriptBox["k", "^"]}]}], " ", ",", " ", 
         RowBox[{"r", "<", " ", "R"}]}]},
       {
        RowBox[{
         RowBox[{"B", " ", "=", "0"}], " ", ",", " ", 
         RowBox[{"r", " ", ">", " ", "R"}]}]}
      }], "}"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"Electromagnetic", " ", "tensor", " ", "is"}], " "}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SuperscriptBox["F", "\[Mu]\[Nu]"], " ", "=", " ", 
    RowBox[{"(", GridBox[{
       {"0", 
        RowBox[{"-", 
         SubscriptBox["E", "1"]}], 
        RowBox[{"-", 
         SubscriptBox["E", "2"]}], 
        RowBox[{"-", 
         SubscriptBox["E", "3"]}]},
       {
        SubscriptBox["E", "1"], "0", 
        SubscriptBox["B", "3"], 
        RowBox[{"-", 
         SubscriptBox["B", "2"]}]},
       {
        SubscriptBox["E", "2"], 
        RowBox[{"-", 
         SubscriptBox["B", "3"]}], "0", 
        SubscriptBox["B", "1"]},
       {
        SubscriptBox["E", "3"], 
        SubscriptBox["B", "2"], 
        RowBox[{"-", 
         SubscriptBox["B", "1"]}], "0"}
      }], ")"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
   "The", " ", "electromagnetic", " ", "tensor", " ", "in", " ", "this", " ", 
    "frame", " ", "will", " ", "be", " ", "given", " ", "by"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
